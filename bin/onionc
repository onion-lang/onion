#!/bin/sh

# Use java from PATH if JAVA_HOME is not set
if [ -z "$JAVA_HOME" ]; then
    JAVA_CMD="java"
else
    JAVA_CMD="$JAVA_HOME/bin/java"
fi

if [ -z "$ONION_HOME" ]; then
    SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
    ONION_HOME=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
fi

# Check if java is available
if ! command -v "$JAVA_CMD" > /dev/null 2>&1; then
    echo "Error: Java not found. Please install Java or set JAVA_HOME environment variable."
    exit 1
fi

USER_CLASSPATH="$CLASSPATH"

CLASSPATH="$ONION_HOME/onion.jar"
if [ -d "$ONION_HOME/lib" ]; then
    for jar in "$ONION_HOME/lib"/*.jar; do
        if [ -f "$jar" ]; then
            CLASSPATH="$CLASSPATH:$jar"
        fi
    done
fi

if [ -n "$USER_CLASSPATH" ]; then
    CLASSPATH="$CLASSPATH:$USER_CLASSPATH"
fi

# Run the Onion compiler
exec "$JAVA_CMD" -classpath "$CLASSPATH" onion.tools.CompilerFrontend "$@"
