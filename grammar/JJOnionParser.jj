PARSER_BEGIN(JJOnionParser)
package onion.compiler.parser;
import onion.compiler.AST;
import onion.compiler.Location;
import onion.compiler.Parser;
import onion.compiler.toolbox.*;
import scala.Tuple2;
import scala.collection.immutable.*;
import scala.collection.mutable.ArrayBuffer;
import scala.collection.mutable.Buffer;
import scala.Option;
import scala.Option$;
import static onion.compiler.AST.append;
import java.util.Stack;
import java.util.ArrayList;

@SuppressWarnings("unchecked")
public class JJOnionParser implements Parser {
  private int mset; // used for semantic lookahead

  // ========== Error Recovery Support ==========
  private boolean errorRecoveryMode = false;
  private ArrayList<ParseError> collectedErrors = new ArrayList<ParseError>();
  private int maxErrors = 10; // Maximum number of errors to collect before giving up

  /**
   * Represents a parse error with location and message.
   */
  public static class ParseError {
    public final int line;
    public final int column;
    public final String found;
    public final String expected;

    public ParseError(int line, int column, String found, String expected) {
      this.line = line;
      this.column = column;
      this.found = found;
      this.expected = expected;
    }

    @Override
    public String toString() {
      return "ParseError at " + line + ":" + column + " - found '" + found + "', expected " + expected;
    }
  }

  /**
   * Enable error recovery mode to collect multiple errors.
   * @param maxErrors Maximum number of errors to collect before stopping
   */
  public void enableErrorRecovery(int maxErrors) {
    this.errorRecoveryMode = true;
    this.maxErrors = maxErrors;
    this.collectedErrors.clear();
  }

  /**
   * Disable error recovery mode.
   */
  public void disableErrorRecovery() {
    this.errorRecoveryMode = false;
  }

  /**
   * Get all collected errors.
   */
  public ArrayList<ParseError> getCollectedErrors() {
    return new ArrayList<ParseError>(collectedErrors);
  }

  /**
   * Check if there are any collected errors.
   */
  public boolean hasErrors() {
    return !collectedErrors.isEmpty();
  }

  /**
   * Collect an error and optionally continue parsing.
   * @return true if parsing should continue, false if should stop
   */
  private boolean collectError(Token errorToken, String expected) {
    if (!errorRecoveryMode) {
      return false; // Don't collect, let normal exception handling occur
    }

    collectedErrors.add(new ParseError(
      errorToken.beginLine,
      errorToken.beginColumn,
      errorToken.image,
      expected
    ));

    return collectedErrors.size() < maxErrors;
  }

  /**
   * Panic-mode skip for top-level error recovery. Consumes tokens while
   * tracking brace depth (relative to the error position) and stops:
   *   - just BEFORE a type-declaration keyword at relative depth zero
   *     (so the next iteration can parse it as a fresh declaration), or
   *   - just AFTER the '}' that closes the enclosing declaration, or
   *   - just AFTER a ';' or newline at relative depth zero.
   * @return true if a sync point was found, false if EOF was reached
   */
  private boolean skipToToplevelSyncPoint() {
    int depth = 0;
    while (true) {
      Token next = getToken(1);
      if (next == null || next.kind == 0) { // 0 is EOF
        return false;
      }
      String img = next.image;
      if (depth == 0 && isDeclarationStart(img)) {
        return true; // leave the keyword for the next parse attempt
      }
      getNextToken(); // consume
      if ("{".equals(img)) {
        depth++;
      } else if ("}".equals(img)) {
        if (depth > 0) depth--;
        else return true; // closed the enclosing declaration
      } else if (depth == 0 && (";".equals(img) || (img != null && img.contains("\n") && states.isEmpty()))) {
        return true;
      }
    }
  }

  /**
   * foreach (k, v) in map { body } desugars to iterating the entry set:
   * foreach __e: Map$Entry in map.entrySet() { val k = __e.getKey(); val v = __e.getValue(); { body } }
   */
  private AST.ForeachExpression desugarMapForeach(Location loc, String kName, String vName, AST.Expression mapExpr, AST.BlockExpression body) {
    String entryName = "__foreach_entry";
    AST.TypeNode entryType = new AST.TypeNode(loc, new AST.ReferenceType("java.util.Map$Entry", true), false);
    AST.Argument entryArg = new AST.Argument(loc, entryName, entryType, null, false);
    AST.Expression entrySet = new AST.MethodCall(loc, mapExpr, "entrySet", (List<AST.Expression>)AST.NIL());
    AST.Expression getKey = new AST.MethodCall(loc, new AST.Id(loc, entryName), "getKey", (List<AST.Expression>)AST.NIL());
    AST.Expression getValue = new AST.MethodCall(loc, new AST.Id(loc, entryName), "getValue", (List<AST.Expression>)AST.NIL());
    ArrayBuffer<AST.BlockElement> elems = new ArrayBuffer<AST.BlockElement>();
    append(elems, new AST.LocalVariableDeclaration(loc, AST.M_FINAL(), kName, null, getKey));
    append(elems, new AST.LocalVariableDeclaration(loc, AST.M_FINAL(), vName, null, getValue));
    append(elems, body);
    AST.BlockExpression newBody = new AST.BlockExpression(loc, toList(elems));
    return new AST.ForeachExpression(loc, entryArg, entrySet, newBody);
  }

  private AST.Expression rangeNew(Location loc, AST.Expression start, AST.Expression end, boolean inclusive) {
    ArrayBuffer<AST.Expression> args = new ArrayBuffer<AST.Expression>();
    append(args, start);
    append(args, end);
    append(args, new AST.BooleanLiteral(loc, inclusive));
    return new AST.NewObject(loc, new AST.TypeNode(loc, new AST.ReferenceType("onion.Range", true), false), toList(args));
  }

  /**
   * Leading-dot continuation: true when, skipping any EOLs after the current
   * position, the next token is "." or "?.". Lets a method chain span lines.
   * Pure token peeking (no consumption).
   */
  private boolean dotContinuationFollows() {
    int i = 1;
    while (getToken(i).kind == EOL) i++;
    int k = getToken(i).kind;
    return k == DOT || k == SAFE_ACCESS;
  }

  /**
   * Whether primary_suffix should take another iteration: a same-line suffix
   * ([, ?[, ., ?., as, ++, !!, --) starts right here, or a leading-dot
   * continuation follows across newlines. Used as the (...)* loop's sole
   * semantic guard so the loop's continuation set is decided purely here --
   * a syntactic guard whose alternatives can start with a nullable eols()
   * would otherwise pull <EOL> into the first-set and hard-error when the
   * inner choice then fails to match (e.g. an expression-body method
   * followed by a blank line).
   */
  private boolean suffixContinues() {
    int k = getToken(1).kind;
    if (k == SAFE_INDEX || k == DOT || k == SAFE_ACCESS || k == K_AS || k == NOT_NULL) {
      return true;
    }
    String img = getToken(1).image;
    if ("[".equals(img) || "++".equals(img) || "--".equals(img)) {
      return true;
    }
    return dotContinuationFollows();
  }

  /**
   * Pipeline continuation: true when, skipping any EOLs after the current
   * position, the next token is |> — so a pipeline can continue on the next
   * line. Pure token peeking (no consumption), mirroring dotContinuationFollows.
   */
  private boolean pipeContinuationFollows() {
    int i = 1;
    while (getToken(i).kind == EOL) i++;
    return getToken(i).kind == PIPELINE;
  }

  /**
   * Desugars e |> rhs by injecting e as the first argument of the call on the
   * right-hand side: f -> f(e); f(a) -> f(e, a); obj.m -> obj.m(e);
   * obj.m(a) -> obj.m(e, a); C::m(a) -> C::m(e, a).
   */
  private AST.Expression pipeInto(Location loc, AST.Expression value, AST.Expression rhs) throws ParseException {
    if (rhs instanceof AST.UnqualifiedMethodCall) {
      AST.UnqualifiedMethodCall c = (AST.UnqualifiedMethodCall) rhs;
      return new AST.UnqualifiedMethodCall(loc, c.name(), AST.prependToList(c.args(), value), c.typeArgs());
    } else if (rhs instanceof AST.Id) {
      AST.Id id = (AST.Id) rhs;
      ArrayBuffer<AST.Expression> args = new ArrayBuffer<AST.Expression>();
      append(args, value);
      return new AST.UnqualifiedMethodCall(loc, id.name(), toList(args));
    } else if (rhs instanceof AST.MethodCall) {
      AST.MethodCall c = (AST.MethodCall) rhs;
      return new AST.MethodCall(loc, c.target(), c.name(), AST.prependToList(c.args(), value), c.typeArgs());
    } else if (rhs instanceof AST.MemberSelection) {
      AST.MemberSelection s = (AST.MemberSelection) rhs;
      ArrayBuffer<AST.Expression> args = new ArrayBuffer<AST.Expression>();
      append(args, value);
      return new AST.MethodCall(loc, s.target(), s.name(), toList(args));
    } else if (rhs instanceof AST.StaticMethodCall) {
      AST.StaticMethodCall c = (AST.StaticMethodCall) rhs;
      return new AST.StaticMethodCall(loc, c.typeRef(), c.name(), AST.prependToList(c.args(), value), c.typeArgs());
    } else if (rhs instanceof AST.StaticMemberSelection) {
      AST.StaticMemberSelection s = (AST.StaticMemberSelection) rhs;
      ArrayBuffer<AST.Expression> args = new ArrayBuffer<AST.Expression>();
      append(args, value);
      return new AST.StaticMethodCall(loc, s.typeRef(), s.name(), toList(args));
    } else {
      ParseException e = new ParseException(
        "the right-hand side of |> must be a call or a function name");
      e.currentToken = token;
      throw e;
    }
  }

  /**
   * Desugars a scheme-prefixed raw literal token (re"..."/file"..."/http"...)
   * into the unqualified call <prefix>("raw"), keeping the body verbatim.
   */
  private AST.Expression schemeCall(Token t, int prefixLen) {
    String name = t.image.substring(0, prefixLen);
    String raw = t.image.substring(prefixLen + 1, t.image.length() - 1);
    ArrayBuffer<AST.Expression> args = new ArrayBuffer<AST.Expression>();
    append(args, new AST.StringLiteral(p(t), raw));
    return new AST.UnqualifiedMethodCall(p(t), name, toList(args));
  }

  private boolean isDeclarationStart(String img) {
    return "class".equals(img) || "interface".equals(img) || "record".equals(img)
        || "enum".equals(img) || "extension".equals(img) || "type".equals(img)
        || "trait".equals(img) || "instance".equals(img);
  }

  /**
   * Summarize the expected tokens of a ParseException for collected errors.
   */
  private String expectedSummary(ParseException e) {
    if (e.expectedTokenSequences == null || e.expectedTokenSequences.length == 0) {
      return "valid token";
    }
    StringBuilder sb = new StringBuilder();
    java.util.LinkedHashSet<String> seen = new java.util.LinkedHashSet<String>();
    for (int[] seq : e.expectedTokenSequences) {
      if (seq.length > 0) seen.add(e.tokenImage[seq[0]]);
    }
    int shown = 0;
    for (String image : seen) {
      if (shown == 4) { sb.append(", ... (").append(seen.size() - shown).append(" more)"); break; }
      if (sb.length() > 0) sb.append(", ");
      sb.append(image);
      shown++;
    }
    return sb.length() == 0 ? "valid token" : sb.toString();
  }

  private boolean no(int m, int mset) {
    return (m & mset) == 0;
  }

  private boolean la(String s) {
    Token t = getToken(1);
    return t != null && t.image.equals(s);
  }

  private boolean la2(String s) {
    Token t = getToken(2);
    return t != null && t.image.equals(s);
  }

  /**
   * Disambiguates `new C[...]` between a generic instantiation (type-argument
   * list, e.g. `new Box[String]`, `new ArrayList[String]()`) and an array
   * allocation (dimension expression, e.g. `new String[n]`, `new Int[3]`,
   * `new Int[n][m]`). Pure token peeking; assumes getToken(1) is "[".
   *
   * Returns true when the brackets should be read as type arguments:
   *   - the matching "]" is immediately followed by "(" (constructor call), or
   *   - the bracket content is unambiguously "type-shaped": multiple args
   *     (comma), a wildcard ("?"/extends/super), a nested generic ("["), or an
   *     FQCN, or a single primitive type keyword / Capitalized identifier (type
   *     naming convention).
   * Returns false (array dimension) for an integer literal, a lower-case / "_"
   * identifier (variable convention), a method call / member access inside the
   * brackets (e.g. `new Int[arr.length]`, `new String[list.size()]`), or any
   * other compound size expression. A top-level "." or "(" inside the brackets
   * marks a value expression, NOT a type, unless a constructor "(" follows "]".
   */
  private boolean newBracketsAreTypeArgs() {
    // A primitive element type never takes type arguments, so its "[..]" is always an array
    // size -- e.g. new Int[N] where N is an (uppercase) variable, not a type argument.
    switch (getToken(0).kind) {
      case K_INT: case K_LONG: case K_BYTE: case K_SHORT: case K_CHAR:
      case K_FLOAT: case K_DOUBLE: case K_BOOLEAN:
        return false;
      default:
        break;
    }
    // getToken(1) is "[". Scan the balanced first bracket group.
    int depth = 0;
    int i = 1;
    int firstKind = -1;            // first significant token kind inside depth 1
    String firstImage = null;
    int topLevelTokens = 0;        // count of depth-1 tokens (excluding brackets)
    boolean sawTypeMarker = false; // comma / ? / extends / super / FQCN at top level
    boolean sawValueMarker = false;// "." or "(" at top level => value expression
    boolean sawNestedBracket = false;
    int closeIndex = -1;
    while (true) {
      Token t = getToken(i);
      if (t == null || t.kind == EOF) break;
      int k = t.kind;
      if (k == LBRACKET) {
        depth++;
        if (depth > 1) sawNestedBracket = true;
        i++;
        continue;
      }
      if (k == RBRACKET) {
        depth--;
        if (depth == 0) { closeIndex = i; i++; break; }
        i++;
        continue;
      }
      if (depth == 1 && k != EOL) {
        if (firstKind == -1) { firstKind = k; firstImage = t.image; }
        topLevelTokens++;
        if (k == COMMA || k == QUESTION || k == K_EXTENDS || k == K_SUPER
            || k == FQCN || k == SAFE_INDEX) {
          sawTypeMarker = true;
        } else if (k == DOT || k == LPAREN) {
          // member access / method call => the brackets hold a value expression
          sawValueMarker = true;
        }
      }
      i++;
    }
    if (closeIndex < 0) return true; // malformed; let the type path report it
    // "]" followed by "(" => generic constructor call (e.g. new Box[T](args)).
    int j = closeIndex + 1;
    while (getToken(j) != null && getToken(j).kind == EOL) j++;
    if (getToken(j) != null && getToken(j).kind == LPAREN) return true;
    // A value-expression marker with no trailing constructor "(" => array size.
    if (sawValueMarker) return false;
    if (sawNestedBracket || sawTypeMarker) return true;
    // Single bare token inside the brackets.
    if (topLevelTokens == 1 && firstKind != -1) {
      switch (firstKind) {
        case INTEGER:
          return false; // array size literal
        case K_INT: case K_LONG: case K_BYTE: case K_SHORT: case K_CHAR:
        case K_FLOAT: case K_DOUBLE: case K_BOOLEAN:
          return true;  // primitive used as a type argument
        case ID: {
          if (firstImage == null || firstImage.isEmpty()) return false;
          char c0 = firstImage.charAt(0);
          // Capitalized => type (generic); lower-case / "_" => variable (array).
          return Character.isUpperCase(c0);
        }
        default:
          return false; // anything else (e.g. a value expression) => array
      }
    }
    // Compound content that is not type-shaped => array dimension expression.
    return false;
  }

  private <T> Option<T> option(T value) {
    return Option$.MODULE$.apply(value);
  }

  /*
   * workaround for Scala types being used from Java
   */
  private static <A> List<A> toList(Buffer<A> buffer) {
    return (List<A>)buffer.toList();
  }

  /*
   * workaround for Scala types being used from Java
   */
  private static <A> List<A> asList(A element) {
    ArrayBuffer<A> buffer = new ArrayBuffer<A>();
    append(buffer, element);
    return (List<A>)buffer.toList();
  }

  /*
   * convenience method to create a Location
   */
  private static Location p(Token t) {
    return new Location(t.beginLine, t.beginColumn);
  }

  /*
   * convenience method to create a Location
   */
  private static Location p(int line, int column) {
    return new Location(line, column);
  }

  /*
   * convenience method to get image of a Token
   * For QUOTED_ID tokens, strips the backticks
   */
  private static String c(Token t) {
    String s = t.image;
    if (s.length() >= 2 && s.startsWith("`") && s.endsWith("`")) {
      return s.substring(1, s.length() - 1);
    }
    return s;
  }

  /*
   * The boxed-class name for a basic-type keyword, so that a keyword can be used
   * as a static-call receiver: Long::toString -> java.lang.Long.toString.
   */
  private static String boxedName(String prim) {
    if ("Int".equals(prim))     return "java.lang.Integer";
    if ("Long".equals(prim))    return "java.lang.Long";
    if ("Double".equals(prim))  return "java.lang.Double";
    if ("Float".equals(prim))   return "java.lang.Float";
    if ("Boolean".equals(prim)) return "java.lang.Boolean";
    if ("Byte".equals(prim))    return "java.lang.Byte";
    if ("Short".equals(prim))   return "java.lang.Short";
    if ("Char".equals(prim))    return "java.lang.Character";
    return prim;
  }

  /*
   * converience method to create substring
   */
  private static String sub(String s, int sindex, int eindex) {
    return s.substring(sindex, eindex);
  }

  /*
   * Returns a String which last character of s is omitted.
   */
  private static String chop(String s) {
    return s.substring(0, s.length() - 1);
  }

  /*
   * Returns a String which first and last character of s is omitted.
   */
  private static String chopEdge(String s) {
    return s.substring(1, s.length() - 1);
  }

  private static char unescapeChar(char c) {
    switch(c){
    case 'n' : return '\n';
    case 't' : return '\t';
    case 'b' : return '\b';
    case 'r' : return '\r';
    case 'f' : return '\f';
    case '\\': return '\\';
    case '\'': return '\'';
    case '"' : return '"';
    case '#' : return '#';
    default  : return c;
    }
  }

  private static String unescape(String s) {
    StringBuffer b = new StringBuffer();
    int len = s.length();
    for(int i = 0; i < len; i++){
      char c = s.charAt(i);
      if(c != '\\'){
        b.append(c);
        continue;
      }
      i++;
      b.append(unescapeChar(s.charAt(i)));
    }
    return new String(b);
  }

  private Stack<Integer> states = new Stack<Integer>();

  private void enterState(int state) {
    int oldState = token_source.curLexState;
    states.push(oldState);
    token_source.SwitchTo(state);
  }

  private void leaveState() {
    token_source.SwitchTo(states.pop());
  }

  private void enterDefault() {
    enterState(DEFAULT);
  }

  private void leaveDefault() {
    leaveState();
  }

  private void enterSection() {
    enterState(IN_STATEMENT);
  }

  private void leaveSection() {
    leaveState();
  }

  /**
   * Build a whitespace prefix so the embedded-expression sub-parser reports
   * positions in the coordinates of the original file. exprStartInStr is the
   * index of the expression inside the (quote-stripped) string content;
   * quoteLen is the length of the opening quote (1 or 3).
   */
  private static String interpolationPadding(String str, int exprStartInStr, Location loc, int quoteLen) {
    int nlCount = 0;
    int lastNl = -1;
    for (int i = 0; i < exprStartInStr; i++) {
      if (str.charAt(i) == '\n') { nlCount++; lastNl = i; }
    }
    int line;
    int col;
    if (nlCount == 0) {
      line = loc.line();
      col = loc.column() + quoteLen + exprStartInStr;
    } else {
      line = loc.line() + nlCount;
      col = exprStartInStr - lastNl;
    }
    StringBuilder sb = new StringBuilder();
    for (int i = 1; i < line; i++) sb.append('\n');
    for (int i = 1; i < col; i++) sb.append(' ');
    return sb.toString();
  }

  /**
   * Finds the next real (non-escaped) interpolation start "#{" in {@code str}
   * starting from {@code pos}.  An escaped interpolation "\#{" is skipped and
   * does not trigger interpolation — the backslash is consumed by the lexer and
   * {@code unescape} turns "\#" into "#".
   */
  private static int findInterpStart(String str, int pos) {
    while (true) {
      int idx = str.indexOf("#{", pos);
      if (idx == -1) return -1;
      // Check whether the '#' is preceded by a backslash (escaped interpolation).
      // Count consecutive backslashes: an even number means the last one is itself
      // escaped, so the '#' is NOT escaped; an odd number means it IS escaped.
      int slashes = 0;
      int k = idx - 1;
      while (k >= 0 && str.charAt(k) == '\\') { slashes++; k--; }
      if (slashes % 2 == 0) return idx; // not escaped
      pos = idx + 1; // escaped — skip and keep searching
    }
  }

  private AST.Expression parseInterpolatedString(Location loc, String str) throws ParseException {
    // Remove quotes
    str = str.substring(1, str.length() - 1);

    ArrayBuffer<String> parts = new ArrayBuffer<String>();
    ArrayBuffer<AST.Expression> expressions = new ArrayBuffer<AST.Expression>();

    int start = 0;
    int pos = 0;

    while (pos < str.length()) {
      int interpStart = findInterpStart(str, pos);
      if (interpStart == -1) {
        // No more interpolations
        append(parts, unescape(str.substring(start)));
        break;
      }

      // Add the string part before interpolation
      append(parts, unescape(str.substring(start, interpStart)));

      // Find the closing brace
      int braceCount = 1;
      int interpEnd = interpStart + 2;
      while (interpEnd < str.length() && braceCount > 0) {
        char c = str.charAt(interpEnd);
        if (c == '"') {
          // Skip over a nested string literal so its braces don't count
          interpEnd++;
          while (interpEnd < str.length() && str.charAt(interpEnd) != '"') {
            if (str.charAt(interpEnd) == '\\') interpEnd++;
            interpEnd++;
          }
        } else if (c == '{') braceCount++;
        else if (c == '}') braceCount--;
        interpEnd++;
      }

      if (braceCount > 0) {
        throw new ParseException("Unclosed interpolation #{...} in string at " + loc + " (string literals inside #{...} are not supported)");
      }

      // Parse the expression inside, padded so positions match the file
      String exprStr = str.substring(interpStart + 2, interpEnd - 1);
      String padding = interpolationPadding(str, interpStart + 2, loc, 1);
      JJOnionParser exprParser = new JJOnionParser(new java.io.StringReader(padding + exprStr));
      try {
        AST.Expression expr = exprParser.term();
        append(expressions, expr);
      } catch (Exception e) {
        throw new ParseException("Invalid expression in string interpolation: " + exprStr + " at " + loc);
      }

      start = interpEnd;
      pos = interpEnd;
    }

    // If we ended with an expression, add an empty string part
    if (parts.size() == expressions.size()) {
      append(parts, "");
    }

    return new AST.StringInterpolation(loc, toList(parts), toList(expressions));
  }

  /**
   * Parse a multi-line interpolated string (without unescape processing).
   * Content is preserved as-is except for interpolation expressions.
   */
  private AST.Expression parseMultiLineInterpolatedString(Location loc, String str) throws ParseException {
    // Remove the triple quotes (""" from start and end)
    str = str.substring(3, str.length() - 3);

    ArrayBuffer<String> parts = new ArrayBuffer<String>();
    ArrayBuffer<AST.Expression> expressions = new ArrayBuffer<AST.Expression>();

    int start = 0;
    int pos = 0;

    while (pos < str.length()) {
      int interpStart = str.indexOf("#{", pos);
      if (interpStart == -1) {
        // No more interpolations - preserve content as-is
        append(parts, str.substring(start));
        break;
      }

      // Add the string part before interpolation (no unescape)
      append(parts, str.substring(start, interpStart));

      // Find the closing brace
      int braceCount = 1;
      int interpEnd = interpStart + 2;
      while (interpEnd < str.length() && braceCount > 0) {
        char c = str.charAt(interpEnd);
        if (c == '"') {
          // Skip over a nested string literal so its braces don't count
          interpEnd++;
          while (interpEnd < str.length() && str.charAt(interpEnd) != '"') {
            if (str.charAt(interpEnd) == '\\') interpEnd++;
            interpEnd++;
          }
        } else if (c == '{') braceCount++;
        else if (c == '}') braceCount--;
        interpEnd++;
      }

      if (braceCount > 0) {
        throw new ParseException("Unclosed interpolation #{...} in multi-line string at " + loc + " (string literals inside #{...} are not supported)");
      }

      // Parse the expression inside, padded so positions match the file
      String exprStr = str.substring(interpStart + 2, interpEnd - 1);
      String padding = interpolationPadding(str, interpStart + 2, loc, 3);
      JJOnionParser exprParser = new JJOnionParser(new java.io.StringReader(padding + exprStr));
      try {
        AST.Expression expr = exprParser.term();
        append(expressions, expr);
      } catch (Exception e) {
        throw new ParseException("Invalid expression in string interpolation: " + exprStr + " at " + loc);
      }

      start = interpEnd;
      pos = interpEnd;
    }

    // If we ended with an expression, add an empty string part
    if (parts.size() == expressions.size()) {
      append(parts, "");
    }

    return new AST.StringInterpolation(loc, toList(parts), toList(expressions));
  }

  /**
   * Extract content from multi-line string (remove triple quotes).
   */
  private static String chopMultiLineEdge(String s) {
    return s.substring(3, s.length() - 3);
  }
}
PARSER_END(JJOnionParser)

<DEFAULT> SKIP:
{
  "\r\n"
| "\t"
| "\f"
| "\r"
| "\n"
| " "
}

<IN_STATEMENT> SKIP:
{
  " "
| "\t"
| "\f"
}

<IN_STATEMENT> TOKEN:
{
  <EOL: ("\r\n" | "\r" | "\n")>
}

/*
* COMMENTS
*/
<DEFAULT, IN_STATEMENT>
SPECIAL_TOKEN:
{
  <MULTI_LINE_COMMENT: "/*" (~["*"])*  "*" ("*" | (~["*", "/"] (~["*"])* "*"))* "/">
| <LINE_COMMENT:       "//" (~["\r", "\n"])*>
| <SHELL_COMMENT:      "#!" (~["\r", "\n"])*>
}

/*
* KEYWORDS
*/
<DEFAULT, IN_STATEMENT>
TOKEN:
{
  <K_ABSTRACT:     "abstract"     >
| <K_AND:          "and"          >
| <K_BOOLEAN:      "Boolean" >
| <K_EXTENDS:     "extends"     >
| <K_BREAK:        "break"        >
| <K_BYTE:         "Byte" >
| <K_CASE:         "case"         >
| <K_CHAR:         "Char"  >
| <K_CLASS:        "class"        >
| <K_RECORD:       "record"       >
| <K_RET:          "ret"          >
| <K_CONST:        "const"        >
| <K_CONTINUE:     "continue"    >
| <K_DEF:          "def"          >
| <K_DO:           "do"           >
| <K_DOUBLE:       "Double"      >
| <K_ELSE:         "else"         >
| <K_ENUM:         "enum"         >
| <K_EXTENSION:    "extension"    >
| <K_FALSE:        "false"        >
| <K_FINALLY:      "finally"      >
| <K_FINAL:        "final"        >
| <K_FLOAT:        "Float" >
| <K_FOR:          "for"          >
| <K_FOREACH:      "foreach"      >
| <K_FORWARD:      "forward"      >
| <K_GOTO:         "goto"         >
| <K_IF:           "if"           >
| <K_IMPORT:       "import"       >
| <K_AS:           "as"           >
| <K_INT:          "Int"  >
| <K_INTERFACE:    "interface"    >
| <K_TRAIT:        "trait"        >
| <K_INSTANCE:     "instance"     >
| <K_INTERNAL:     "internal"     >
| <K_IS:           "is"           >
| <K_LONG:         "Long"         >
| <K_MODULE:       "module"       >
| <K_NEW:          "new"          >
| <K_THIS:         "this"         >
| <K_NULL:         "null"         >
| <K_OR:           "or"           >
| <K_OVERRIDE:     "override"     >
| <K_PRIVATE:      "private"      >
| <K_PROTECTED:    "protected"    >
| <K_PUBLIC:       "public"       >
| <K_CATCH:        "catch"        >
| <K_RETURN:       "return"       >
| <K_SELECT:       "select"       >
| <K_SELF:         "self"         >
| <K_SHORT:        "Short"        >
| <K_STATIC:       "static"       >
| <K_SUPER:        "super"        >
| <K_SEALED:       "sealed"       >
| <K_SYNCHRONIZED: "synchronized" >
| <K_THROW:        "throw"        >
| <K_THROWS:       "throws"       >
| <K_TRUE:         "true"         >
| <K_TRY:          "try"          >
| <K_TYPE:         "type"         >
| <K_VAL:          "val"          >
| <K_VAR:          "var"          >
| <K_VOID:         "void" | "Unit" >
| <K_VOLATILE:     "volatile"     >
| <K_WHEN:         "when"         >
| <K_WHILE:        "while"        >
}


/*
* OPERATORS
*/
<DEFAULT, IN_STATEMENT>
TOKEN : {
  <PLUS:           "+"            >
| <MINUS:          "-"            >
| <STAR:           "*"            >
| <SLASH:          "/"            >
| <PERC:           "%"            >
| <LTEQ:           "<="           >
| <GTEQ:           ">="           >
| <LT:             "<"            >
| <GT:             ">"            >
| <ARROW:          "->"           >
| <DOTDOT_LT:      "..<"          >
| <DOTDOT:         ".."           >
| <ARROW2:         "=>"           >
| <LARROW:         "<-"           >
| <SUBTYPE:        "<:"           >
| <NOT:            "!"            >
| <AMP:            "&"            >
| <AND:            "&&"           >
| <BAR:            "|"            >
| <OR:             "||"           >
| <PIPELINE:       "|>"           >
| <EOR:            "^"            >
| <BN:             "~"            >
| <L2S:            "<<"           >
| <R2S:            ">>"           >
| <R3S:            ">>>"          >
| <ASSIGN:         "="            >
| <EQ:             "=="           >
| <NOTEQ:          "!="           >
| <NOT_NULL:       "!!"           >
| <REFEQ:          "==="          >
| <REFNOTEQ:       "!=="          >
| <ADDEQ:          "+="           >
| <SUBEQ:          "-="           >
| <MULEQ:          "*="           >
| <DIVEQ:          "/="           >
| <MODEQ:          "%="           >
| <ANDEQ:          "&="           >
| <OREQ:           "|="           >
| <XOREQ:          "^="           >
| <LSHIFTEQ:       "<<="          >
| <RSHIFTEQ:       ">>="          >
| <URSHIFTEQ:      ">>>="         >
| <PLUSPLUS:       "++"           >
| <MINUSMINUS:     "--"           >
| <COLON:          ":"            >
| <SEMI:           ";"            >
| <COLON2:         "::"           >
| <SHARP:          "#"            >
| <DOT:            "."            >
| <ELLIPSIS:        "..."          >
| <LBRACE:         "{"            >
| <RBRACE:         "}"            >
| <BACK_QUOTE:     "`"            >
| <LPAREN:         "("            >
| <RPAREN:         ")"            >
| <COMMA:          ","            >
| <LBRACKET:       "["            >
| <RBRACKET:       "]"            >
| <QUESTION:       "?"            >
| <ELVIS:          "?:"           >
| <SAFE_ACCESS:    "?."           >
| <SAFE_INDEX:     "?["           >
}

/*
 * LITERALS
 */
<DEFAULT, IN_STATEMENT>
TOKEN:
{
  <INTEGER:
    <DECIMAL_LITERAL> (["B","S","L"])?
  | <HEX_LITERAL> (["B","S","L"])?
  | <BINARY_LITERAL> (["B","S","L"])?
  | <OCTAL_LITERAL> (["B","S","L"])?
  >
| <#DECIMAL_LITERAL: ["1"-"9"] (["0"-"9","_"])* >
| <#HEX_LITERAL: "0" ["x","X"] ["0"-"9","a"-"f","A"-"F"] (["0"-"9","a"-"f","A"-"F","_"])* >
| <#BINARY_LITERAL: "0" ["b"] ["0","1"] (["0","1","_"])* >
| <#OCTAL_LITERAL: "0" (["0"-"7","_"])* >
| <FLOAT:
    (["0"-"9"]) (["0"-"9","_"])* "." (["0"-"9"]) (["0"-"9","_"])* (<EXPONENT>)? (["F","f","D","d"])?
  | "." (["0"-"9"]) (["0"-"9","_"])* (<EXPONENT>)? (["F","f","D","d"])?
  | (["0"-"9"]) (["0"-"9","_"])* <EXPONENT> (["F","f","D","d"])?
  | (["0"-"9"]) (["0"-"9","_"])* (<EXPONENT>)? ["F","f","D","d"]
  >
| <#EXPONENT: ["e","E"] (["+","-"])? (["0"-"9"])+ >
| <CHARACTER:
    "'"
    ( (~["'","\\","\n","\r"])
    | ("\\"
        ( ["n","t","b","r","f","\\","'","\""]
        | ["0"-"7"] ( ["0"-"7"] )?
        | ["0"-"3"] ["0"-"7"] ["0"-"7"]
        )
      )
    )
    "'"
  >
| <STRING:
    "\""
    ( (~["\"","\\","\n","\r","#"])
    | ("\\"
        ( ["n","t","b","r","f","\\","'","\"","#"]
        | ["0"-"7"] ( ["0"-"7"] )?
        | ["0"-"3"] ["0"-"7"] ["0"-"7"]
        )
      )
    | "#" ( "{" <INTERP_BODY> "}" )?
    )*
    "\""
  >
| <#INTERP_STRING: "\"" ( ~["\"","\\","\n","\r"] | "\\" ~["\n","\r"] )* "\"" >
| <#INTERP_BODY:
    ( ~["{","}","\"","\n","\r"]
    | <INTERP_STRING>
    | "{" ( ~["{","}","\"","\n","\r"] | <INTERP_STRING> )* "}"
    )*
  >
| <MULTI_LINE_STRING:
    "\"\"\""
    ( ~["\""] | "\"" ~["\""] | "\"\"" ~["\""] )*
    "\"\"\""
  >
// Scheme-prefixed raw string literals: re"..." / file"..." / http"...".
// Raw = no escape processing (a backslash passes through verbatim; \" only
// prevents termination), so regex patterns need no double-backslash. Each
// desugars to the unqualified call <prefix>("..."), resolved through the
// default static imports (onion.Resources), so the literal and the function
// form are exactly equivalent.
| <RE_STRING:   "re\""   ( ~["\"","\\","\n","\r"] | "\\" ~["\n","\r"] )* "\"" >
| <FILE_STRING: "file\"" ( ~["\"","\\","\n","\r"] | "\\" ~["\n","\r"] )* "\"" >
| <HTTP_STRING: "http\"" ( ~["\"","\\","\n","\r"] | "\\" ~["\n","\r"] )* "\"" >
| <ID:       ["a"-"z", "A"-"Z", "_"] (["a"-"z", "A"-"Z", "_", "0"-"9"])* >
| <QUOTED_ID: "`" (~["`"])+ "`" >
| <FQCN:     "#" "<" <ID> ("." <ID>)* ">"                                >
| <ANNOTATION: "@" ["a"-"z", "A"-"Z", "_"] (["a"-"z", "A"-"Z", "_", "0"-"9"])* >  // Annotation syntax
}

/*
 * ERROR TOKEN
 */
<DEFAULT, IN_STATEMENT>
TOKEN:{
  <ERROR: ~[]>
}

AST.CompilationUnit unit() :{
  AST.ModuleDeclaration module = null; AST.ImportClause imports = null;
  AST.Toplevel top = null;  ArrayBuffer<AST.Toplevel> tops = new ArrayBuffer<AST.Toplevel>();
}{
  [module=module_decl()]
  [imports=import_decl()]
  (
    try {
      top=top_level() {append(tops, top);}
    } catch (ParseException e) {
      if (!errorRecoveryMode) { throw e; }
      Token errorToken = (e.currentToken != null && e.currentToken.next != null) ? e.currentToken.next : token;
      if (!collectError(errorToken, expectedSummary(e))) { throw e; }
      if (!skipToToplevelSyncPoint()) {
        // EOF reached while recovering: return what we have, errors are collected
        return new AST.CompilationUnit(p(1, 1), null, module, imports, toList(tops));
      }
    }
  )+ <EOF> {
    return new AST.CompilationUnit(p(1, 1),  null, module, imports, toList(tops));
  }
}

// Helper to accept identifier or quoted identifier (for escaping reserved words)
// Use c(token) to get the identifier name (strips backticks if present)
Token id() :{Token t;}{
    t=<ID> { return t; }
  | t=<QUOTED_ID> { return t; }
}

// Helper for import names - accepts identifiers AND type keywords (Long, Int, etc.)
Token import_id() :{Token t;}{
    t=<ID> { return t; }
  | t=<QUOTED_ID> { return t; }
  | t=<K_LONG> { return t; }
  | t=<K_INT> { return t; }
  | t=<K_SHORT> { return t; }
  | t=<K_BYTE> { return t; }
  | t=<K_CHAR> { return t; }
  | t=<K_FLOAT> { return t; }
  | t=<K_DOUBLE> { return t; }
  | t=<K_BOOLEAN> { return t; }
}

AST.ModuleDeclaration module_decl() :{Token t1, t2; StringBuffer sb = new StringBuffer();}{
  {enterSection();}
  t1="module" t2=id() {sb.append(c(t2));} ("." t2=id() {sb.append("."); sb.append(c(t2));})* eos() {
    return new AST.ModuleDeclaration(p(t1), new String(sb));
  }
}

AST.ImportClause import_decl() :{
  Token t = null, n, star, alias = null, staticMethod = null;
  StringBuffer sb;
  String s = null;
  ArrayBuffer<Tuple2<String, String>> imports = new ArrayBuffer<Tuple2<String, String>>();
  ArrayBuffer<Tuple2<String, String>> staticImports = new ArrayBuffer<Tuple2<String, String>>();
}{
  t="import" "{"
    ( {sb = new StringBuffer(); alias = null; staticMethod = null; enterSection();}
      (LOOKAHEAD(2) n=import_id() "." {sb.append(c(n)); sb.append(".");})+
      (n=import_id() | star="*" {n = star;}) {s = c(n); sb.append(s);}
      [ "::" staticMethod=import_id() ]
      [<K_AS> alias=id() {s = c(alias);}]
      eos_or_block_end()
      {
        if (staticMethod != null) {
          append(staticImports, new Tuple2<String, String>(c(staticMethod), new String(sb)));
        } else {
          append(imports, new Tuple2<String, String>(s, new String(sb)));
        }
      }
    )*
  "}"{ return new AST.ImportClause(p(t), toList(imports), toList(staticImports)); }
}

AST.Toplevel top_level():{int mset = 0; AST.Toplevel top;}{
( LOOKAHEAD({getToken(1).image.equals("break") || getToken(1).image.equals("continue")})
  // Fast-path bare break/continue: the generic LOOKAHEAD(2) below tokenizes two
  // tokens in the DEFAULT lexer state (where EOL is skipped), so `break\n<stmt>`
  // buffers `break <stmt>` and the statement's EOL terminator is lost -- yielding
  // a confusing syntax error instead of E0048/E0049. A 1-token predicate commits
  // to block_element before that happens, so enterSection() can tokenize the EOL.
  top=block_element()
| LOOKAHEAD(2)
  top=block_element()
| LOOKAHEAD("extension")
  top=extension_decl()
| LOOKAHEAD("instance")
  top=instance_decl()
| [mset=modifiers()]
  ( LOOKAHEAD("type")
    top=type_alias_decl(mset)
  | top=type_decl(mset)
  | top=fun_decl(mset)
  | top=var_decl(mset)
  )
) {return top;}
}

AST.ExtensionDeclaration extension_decl() : {
  Token t;
  AST.TypeNode receiverType;
  AST.MethodDeclaration method;
  ArrayBuffer<AST.MethodDeclaration> methods = new ArrayBuffer<AST.MethodDeclaration>();
  int mset = 0;
}{
  t="extension" receiverType=type() "{"
    ({mset = 0;} [mset=modifiers()] method=method_decl(mset) {append(methods, method);})*
  "}" {
    return new AST.ExtensionDeclaration(p(t), receiverType, toList(methods));
  }
}

// `instance Trait[Type] { <method defs> }`: a flat method list like `extension`.
// Lowered in Rewriting to a class implementing the trait interface; instance
// registration / dictionary singleton come in later stages.
AST.InstanceDeclaration instance_decl() : {
  Token t;
  AST.TypeNode traitType;
  AST.MethodDeclaration method;
  ArrayBuffer<AST.MethodDeclaration> methods = new ArrayBuffer<AST.MethodDeclaration>();
  int mset = 0;
}{
  t="instance" traitType=type() "{"
    ({mset = 0;} [mset=modifiers()] method=method_decl(mset) {append(methods, method);})*
  "}" [";"] {
    return new AST.InstanceDeclaration(p(t), AST.M_PUBLIC(), traitType, toList(methods));
  }
}

AST.GlobalVariableDeclaration var_decl(int modifiers) : {
  Token keyword, name;
  AST.TypeNode ty = null;
  AST.Expression e = null;
}{
  {enterSection();}
  (keyword="val" | keyword="var") name=id() ":" ty=type() ["=" e=term()] eos() {
    int declMods = modifiers;
    if (keyword.image.equals("val")) declMods |= AST.M_FINAL();
    return new AST.GlobalVariableDeclaration(
      p(keyword), declMods, c(name), ty, e
    );
  }
}

AST.TypeAliasDeclaration type_alias_decl(int modifiers) : {
  Token t, name;
  List<AST.TypeParameter> tparams = scala.collection.immutable.List$.MODULE$.<AST.TypeParameter>empty();
  AST.TypeNode targetType;
}{
  {enterSection();}
  t="type" name=id() [tparams=type_params()] "=" targetType=type() eos() {
    return new AST.TypeAliasDeclaration(p(t), modifiers, c(name), tparams, targetType);
  }
}

AST.FunctionDeclaration fun_decl(int modifiers) : {
  Token t1, t2;
  List<AST.Argument> args = (List<AST.Argument>)AST.NIL();
  AST.TypeNode ty = null;
  AST.BlockExpression b = null;
  AST.Expression e = null;
  List<AST.TypeParameter> tparams = scala.collection.immutable.List$.MODULE$.<AST.TypeParameter>empty();
  List<AST.TypeNode> throwsTypes = scala.collection.immutable.List$.MODULE$.<AST.TypeNode>empty();
  List<AST.Annotation> anns = scala.collection.immutable.List$.MODULE$.<AST.Annotation>empty();
}{
  anns=annotations() t1="def" t2=id() [tparams=type_params()] ["(" args=args() ")"] [":" ty=return_type()] [throwsTypes=throws_clause()]
  (  (b=block() | {enterSection();} eos()) {
       return new AST.FunctionDeclaration(p(t1), modifiers, c(t2), args, ty, b, tparams, throwsTypes, anns);
     }
  |  ({enterSection();} "=" eols() e=term() eos()) {
       return new AST.FunctionDeclaration(
         p(t1), modifiers, c(t2), args, ty,
         new AST.BlockExpression(p(t1), asList(new AST.ReturnExpression(p(t1), e))),
         tparams, throwsTypes, anns
       );
     }
  )
}

List<AST.TypeNode> throws_clause() : {
  AST.TypeNode ty;
  ArrayBuffer<AST.TypeNode> types = new ArrayBuffer<AST.TypeNode>();
}{
  "throws" ty=class_type() {append(types, ty);}
  ("," ty=class_type() {append(types, ty);})*
  {return toList(types);}
}

AST.TypeDeclaration type_decl(int modifiers) :{AST.TypeDeclaration ty = null;}{
  (ty=interface_decl(modifiers) | ty=trait_decl(modifiers) | ty=class_decl(modifiers) | ty=record_decl(modifiers) | ty=enum_decl(modifiers)) {return ty;}
}

AST.BlockExpression block():{Token t; List<AST.BlockElement> elements = (List<AST.BlockElement>)AST.NIL(); AST.BlockExpression s;}{
  t="{" eols() [elements=block_elements()] eols() "}" {return new AST.BlockExpression(p(t), elements);}
}

List<AST.BlockElement> block_elements():{ AST.BlockElement element; ArrayBuffer<AST.BlockElement> elements = new ArrayBuffer<AST.BlockElement>(); }{
  (element=block_element() { append(elements, element); })+ {return toList(elements);}
}

int modifiers():{ mset = 0; Token t = null, last = null; }{
  ( t = "final"        {mset = AST.M_FINAL();}
  | t = "internal"     {mset = AST.M_INTERNAL();}
  | t = "volatile"     {mset = AST.M_VOLATILE();}
  | t = "abstract"     {mset = AST.M_ABSTRACT();}
  | t = "synchronized" {mset = AST.M_SYNCHRONIZED();}
  | t = "static"       {mset = AST.M_STATIC();}
  | t = "override"     {mset = AST.M_OVERRIDE();}
  | t = "sealed"       {mset = AST.M_SEALED();}
  )
  ( LOOKAHEAD(1,{no(AST.M_FINAL(), mset)})        t = "final"        { mset |= AST.M_FINAL(); }
  | LOOKAHEAD(1,{no(AST.M_INTERNAL(), mset)})     t = "internal"     { mset |= AST.M_INTERNAL(); }
  | LOOKAHEAD(1,{no(AST.M_VOLATILE(), mset)})     t = "volatile"     { mset |= AST.M_VOLATILE(); }
  | LOOKAHEAD(1,{no(AST.M_ABSTRACT(), mset)})     t = "abstract"     { mset |= AST.M_ABSTRACT(); }
  | LOOKAHEAD(1,{no(AST.M_SYNCHRONIZED(), mset)}) t = "synchronized" { mset |= AST.M_SYNCHRONIZED(); }
  | LOOKAHEAD(1,{no(AST.M_STATIC(), mset)})       t = "static"       { mset |= AST.M_STATIC(); }
  | LOOKAHEAD(1,{no(AST.M_OVERRIDE(), mset)})     t = "override"     { mset |= AST.M_OVERRIDE(); }
  | LOOKAHEAD(1,{no(AST.M_SEALED(), mset)})       t = "sealed"       { mset |= AST.M_SEALED(); }
  )* {return mset;}
}

AST.AccessSection default_section() : {
  ArrayBuffer<AST.MemberDeclaration> members = new ArrayBuffer<AST.MemberDeclaration>();
  AST.MemberDeclaration m; int mset; Location location;
}{
  {mset = 0;}
  ([mset=modifiers()] m=member_decl(mset) {
     append(members, m); location = m.location();
   }
  )
  ({mset = 0;} [mset=modifiers()] m=member_decl(mset) {append(members, m);})*
  {return new AST.AccessSection(location, AST.M_PRIVATE(), toList(members));}
}

AST.AccessSection access_section() :{
  ArrayBuffer<AST.MemberDeclaration> members = new ArrayBuffer<AST.MemberDeclaration>();
  Token t; int mset; AST.MemberDeclaration m;
  int sectionType = 0;
}{
  (t="public"    {sectionType = AST.M_PUBLIC();}
  |t="protected" {sectionType = AST.M_PROTECTED();}
  |t="private"   {sectionType = AST.M_PRIVATE();}
  ) ":"
  ({mset = 0;} [mset=modifiers()] m=member_decl(mset) {append(members, m);})*
  {return new AST.AccessSection(p(t), sectionType, toList(members));}
}

AST.MemberDeclaration member_decl(int mset) :{AST.MemberDeclaration m;}{
  LOOKAHEAD(2) m=field_decl(mset)         {return m;}
| LOOKAHEAD(2) m=method_decl(mset)        {return m;}
| LOOKAHEAD(2) m=delegate_decl(mset)      {return m;}
| LOOKAHEAD(2) m=constructor_decl(mset)   {return m;}
}

AST.ClassDeclaration class_decl(int mset) : {
  Token t1, t2; AST.TypeNode ty1 = null, ty2 = null;
  AST.AccessSection sec1 = null;
  AST.AccessSection sec2 = null;
  Option<AST.AccessSection> sec3 = null;
  ArrayBuffer<AST.TypeNode> ty2s = new ArrayBuffer<AST.TypeNode>();
  ArrayBuffer<AST.AccessSection> sec2s = new ArrayBuffer<AST.AccessSection>();
  List<AST.TypeParameter> tparams = scala.collection.immutable.List$.MODULE$.<AST.TypeParameter>empty();
  java.util.ArrayList<AST.Argument> primaryParams = null;
  java.util.ArrayList<Integer> primaryKinds = null; // 0=plain, 1=val, 2=var
  List<AST.Expression> superArgs = null;
  Token pk; AST.Argument pa; int kind;
}{
  t1="class" t2=id() [tparams=type_params()]
  [ "(" {primaryParams = new java.util.ArrayList<AST.Argument>(); primaryKinds = new java.util.ArrayList<Integer>();}
    [ {kind = 0;} [ (pk="val" {kind = 1;} | pk="var" {kind = 2;}) ] pa=argument() {primaryParams.add(pa); primaryKinds.add(kind);}
      ("," {kind = 0;} [ (pk="val" {kind = 1;} | pk="var" {kind = 2;}) ] pa=argument() {primaryParams.add(pa); primaryKinds.add(kind);})*
    ] ")" ]
  [":" ty1=type() [LOOKAHEAD(2) "(" superArgs=terms() ")"]]
  ["<:" ty2=type() {append(ty2s, ty2);} ("," ty2=type() {append(ty2s, ty2);})*]
  ( "{"
    [sec1=default_section()] { sec3 = option(sec1); }
    (sec2=access_section() {append(sec2s, sec2);})*
    "}" [";"]
  | ";"   // body-less: class Dog(name: String, val breed: String) : Animal(name);
  | LOOKAHEAD({getToken(1).kind != LBRACE}) {}
  ) {
    if (sec3 == null) { sec3 = option(sec1); }
    if (primaryParams == null && superArgs != null) {
      // class A : B(args) { } without primary params: synthesize the
      // no-arg constructor delegating to super(args)
      primaryParams = new java.util.ArrayList<AST.Argument>();
      primaryKinds = new java.util.ArrayList<Integer>();
    }
    if (primaryParams != null) {
      // Primary constructor sugar: val/var params become public fields with
      // an auto-generated constructor assigning them; plain params are
      // constructor-only (usable for super arguments)
      ArrayBuffer<AST.MemberDeclaration> members = new ArrayBuffer<AST.MemberDeclaration>();
      ArrayBuffer<AST.BlockElement> assigns = new ArrayBuffer<AST.BlockElement>();
      ArrayBuffer<AST.Argument> ctorArgs = new ArrayBuffer<AST.Argument>();
      for (int i = 0; i < primaryParams.size(); i++) {
        AST.Argument param = primaryParams.get(i);
        int k = primaryKinds.get(i);
        append(ctorArgs, param);
        if (k != 0) {
          int fieldMods = (k == 1) ? AST.M_FINAL() : 0;
          append(members, new AST.FieldDeclaration(param.location(), fieldMods, param.name(), param.typeRef(), null));
          append(assigns, new AST.Assignment(param.location(),
            new AST.MemberSelection(param.location(), new AST.CurrentInstance(param.location()), param.name()),
            new AST.Id(param.location(), param.name())));
        }
      }
      List<AST.Expression> superInits = superArgs != null ? superArgs : (List<AST.Expression>)AST.NIL();
      append(members, new AST.ConstructorDeclaration(
        p(t1), 0, toList(ctorArgs), superInits,
        new AST.BlockExpression(p(t1), toList(assigns))
      ));
      append(sec2s, new AST.AccessSection(p(t1), AST.M_PUBLIC(), toList(members)));
    }
    return new AST.ClassDeclaration(
      p(t1), mset, c(t2), ty1, toList(ty2s), sec3, toList(sec2s), tparams
    );
  }
}

AST.RecordDeclaration record_decl(int mset) : {
  Token t1, t2, rt, mk, lt, enm, et; List<AST.Argument> args, largs;
  AST.TypeNode superType;
  AST.BlockExpression lb, eb;
  ArrayBuffer<AST.TypeNode> superTypes = new ArrayBuffer<AST.TypeNode>();
  List<AST.TypeParameter> tparams = scala.collection.immutable.List$.MODULE$.<AST.TypeParameter>empty();
  String fromRaw = null;
  ArrayBuffer<String> deriveBuf = new ArrayBuffer<String>();
  ArrayBuffer<AST.LawClause> lawBuf = new ArrayBuffer<AST.LawClause>();
  ArrayBuffer<AST.ExampleClause> exBuf = new ArrayBuffer<AST.ExampleClause>();
}{
  t1="record" t2=id() [tparams=type_params()] "(" args=args() ")"
  // Optional `from re"..."` clause (shape-first records). `from` is a soft keyword
  // recognized only when immediately followed by a regex literal, so it stays usable
  // as an ordinary identifier everywhere else. The raw regex body (no re"/" delimiters)
  // drives synthesis of the static parse/parseAll methods in the Rewriting phase.
  [ LOOKAHEAD({getToken(1).image.equals("from") && getToken(2).kind == RE_STRING})
    <ID> rt=<RE_STRING> { fromRaw = rt.image.substring(3, rt.image.length() - 1); }
  ]
  // Optional `derive!(Marker, ...)` clause. `derive` is a soft keyword recognized only
  // when immediately followed by `!`, so it stays usable as an ordinary identifier. The
  // `!` makes macro expansion visible at the use site; each marker drives code synthesis
  // (e.g. Json -> fromJson/toJson) in the Rewriting phase.
  [ LOOKAHEAD({getToken(1).image.equals("derive") && getToken(2).kind == NOT})
    <ID> <NOT> "(" mk=id() {append(deriveBuf, c(mk));}
          ("," mk=id() {append(deriveBuf, c(mk));})* ")"
  ]
  // Optional `law name(p: T) { expr }` / `example [name] { expr }` clauses (B3). Both are
  // soft keywords recognized only here; each becomes a boolean static method the compiler
  // executes at build time (LawCheckPhase). `law` is property-checked over generated args.
  (
    LOOKAHEAD({getToken(1).image.equals("law") && getToken(2).kind == ID})
      <ID> lt=<ID> "(" largs=args() ")" lb=block()
      { append(lawBuf, new AST.LawClause(p(lt), c(lt), largs, lb)); }
  |
    LOOKAHEAD({getToken(1).image.equals("example") && (getToken(2).kind == LBRACE || getToken(2).kind == ID)})
      et=<ID> { enm = null; } [ LOOKAHEAD({getToken(1).kind == ID}) enm=<ID> ] eb=block()
      { append(exBuf, AST.exampleClause(p(et), enm == null ? null : c(enm), eb)); }
  )*
  [ "<:"
    superType = type() {append(superTypes, superType);}
    ("," superType = type() {append(superTypes, superType);})*
  ] [";"] {
    return AST.recordDeclaration(
      p(t1), mset, c(t2), tparams, args, toList(superTypes), fromRaw, toList(deriveBuf),
      toList(lawBuf), toList(exBuf)
    );
  }
}

AST.InterfaceDeclaration interface_decl(int mset) : {
  Token start, name;
  AST.TypeNode superType;
  AST.MethodDeclaration signature;
  ArrayBuffer<AST.TypeNode> superTypes = new ArrayBuffer<AST.TypeNode>();
  ArrayBuffer<AST.MethodDeclaration> signatures = new ArrayBuffer<AST.MethodDeclaration>();
  List<AST.TypeParameter> tparams = scala.collection.immutable.List$.MODULE$.<AST.TypeParameter>empty();
}{
  start = "interface" name = id() [tparams=type_params()]
  [ "<:"
    superType = type() {append(superTypes, superType);}
    ("," superType = type() {append(superTypes, superType);})*
  ] "{"
    (signature = interface_method_decl() {append(signatures, signature); })*
  "}" [";"] {
    return new AST.InterfaceDeclaration(
      p(start), mset, c(name), toList(superTypes), toList(signatures), tparams
    );
  }
}

// A `trait` is (for now) parsed exactly like an interface -- it erases to a JVM
// interface. The type-class machinery (instances, [T: C] constraints, dictionary
// passing) is layered on in later stages; here it just gives the surface syntax.
AST.InterfaceDeclaration trait_decl(int mset) : {
  Token start, name;
  AST.TypeNode superType;
  AST.MethodDeclaration signature;
  ArrayBuffer<AST.TypeNode> superTypes = new ArrayBuffer<AST.TypeNode>();
  ArrayBuffer<AST.MethodDeclaration> signatures = new ArrayBuffer<AST.MethodDeclaration>();
  List<AST.TypeParameter> tparams = scala.collection.immutable.List$.MODULE$.<AST.TypeParameter>empty();
}{
  start = "trait" name = id() [tparams=type_params()]
  [ "<:"
    superType = type() {append(superTypes, superType);}
    ("," superType = type() {append(superTypes, superType);})*
  ] "{"
    (signature = interface_method_decl() {append(signatures, signature); })*
  "}" [";"] {
    return new AST.InterfaceDeclaration(
      p(start), mset, c(name), toList(superTypes), toList(signatures), tparams
    );
  }
}

AST.EnumDeclaration enum_decl(int mset) : {
  Token start, name;
  AST.EnumConstant constant;
  AST.AccessSection sec;
  List<AST.Argument> params = (List<AST.Argument>)AST.NIL();
  ArrayBuffer<AST.EnumConstant> constants = new ArrayBuffer<AST.EnumConstant>();
  ArrayBuffer<AST.AccessSection> sections = new ArrayBuffer<AST.AccessSection>();
}{
  start = "enum" name = id() ["(" params = args() ")"] "{"
    constant = enum_constant() {append(constants, constant);}
    (
      LOOKAHEAD({la(",") && !la2("}")})
      "," constant = enum_constant() {append(constants, constant);}
    )*
    [LOOKAHEAD({la(",") && la2("}")}) "," ] // trailing comma allowed when followed by }
    (sec=access_section() {append(sections, sec);})*
  "}" [";"] {
    return new AST.EnumDeclaration(
      p(start), mset, c(name), params, toList(constants), toList(sections)
    );
  }
}

AST.EnumConstant enum_constant() : {
  Token name;
  List<AST.Expression> args = (List<AST.Expression>)AST.NIL();
}{
  name = id() ["(" args = terms() ")"] {
    return new AST.EnumConstant(p(name), c(name), args);
  }
}

AST.ConstructorDeclaration constructor_decl(int mset) : {
  Token t;
  List<AST.Argument> args = (List<AST.Argument>)AST.NIL();
  List<AST.Expression> params = (List<AST.Expression>)AST.NIL();
  AST.BlockExpression block;
}{
  "def" t="this" ["(" args = args() ")"] [":" "(" params = terms() ")"] block = block() {
    return new AST.ConstructorDeclaration(p(t), mset, args, params, block);
  }
}

List<AST.Annotation> annotations() : {
  ArrayBuffer<AST.Annotation> anns = new ArrayBuffer<AST.Annotation>();
  Token t;
  String name;
}{
  (
    t=<ANNOTATION> {
      // Extract annotation name (remove @ prefix)
      name = t.image.substring(1);
      append(anns, new AST.Annotation(p(t), name));
    }
    eols()
  )*
  {return toList(anns);}
}

AST.MethodDeclaration method_decl(int mset) : {
  Token t;
  List<AST.Argument> args = (List<AST.Argument>)AST.NIL();
  AST.TypeNode ty = null;
  AST.BlockExpression b = null;
  AST.Expression e = null;
  List<AST.TypeParameter> tparams = scala.collection.immutable.List$.MODULE$.<AST.TypeParameter>empty();
  List<AST.TypeNode> throwsTypes = scala.collection.immutable.List$.MODULE$.<AST.TypeNode>empty();
  List<AST.Annotation> anns = scala.collection.immutable.List$.MODULE$.<AST.Annotation>empty();
}{
  anns=annotations() "def" t=id() [tparams=type_params()] ["(" args=args() ")"] [":" ty=return_type()] [throwsTypes=throws_clause()]
  (  {enterSection();} "=" eols() e=term() eos_or_block_end() {
       return new AST.MethodDeclaration(
         p(t), mset, c(t), args, ty,
         new AST.BlockExpression(p(t), asList(new AST.ReturnExpression(p(t), e))),
         tparams, throwsTypes, anns
       );
     }
  |  b=block() {
       return new AST.MethodDeclaration(p(t), mset, c(t), args, ty, b, tparams, throwsTypes, anns);
     }
  |  {enterSection();} eos_or_block_end() {
       // No body: an abstract/interface method. eos_or_block_end (not eos) so a
       // one-line `interface A { def f(): Int }` terminates at the `}`.
       return new AST.MethodDeclaration(p(t), mset, c(t), args, ty, null, tparams, throwsTypes, anns);
     }
  )
}

AST.MethodDeclaration interface_method_decl() : {
  Token n;
  List<AST.Argument> args = (List<AST.Argument>)AST.NIL();
  AST.TypeNode ty  = null;
  AST.BlockExpression b = null;
  AST.Expression e = null;
  List<AST.TypeParameter> tparams = scala.collection.immutable.List$.MODULE$.<AST.TypeParameter>empty();
  List<AST.TypeNode> throwsTypes = scala.collection.immutable.List$.MODULE$.<AST.TypeNode>empty();
}{
  {enterSection();}
  "def" n=id() [tparams=type_params()] ["(" args=args() ")"] [":" ty=return_type()] [throwsTypes=throws_clause()]
  (  "=" eols() e=term() eos_or_block_end() {
       return new AST.MethodDeclaration(
         p(n), AST.M_PUBLIC(), c(n), args, ty,
         new AST.BlockExpression(p(n), asList(new AST.ReturnExpression(p(n), e))),
         tparams, throwsTypes
       );
     }
  |  {leaveSection();} b=block() {
       // A body makes this a default method
       return new AST.MethodDeclaration(p(n), AST.M_PUBLIC(), c(n), args, ty, b, tparams, throwsTypes);
     }
  |  eos_or_block_end() {
       // No body: an abstract interface method. eos_or_block_end (not eos) so a
       // one-line `interface A { def f(): Int }` terminates at the `}`.
       return new AST.MethodDeclaration(p(n), AST.M_PUBLIC(), c(n), args, ty, null, tparams, throwsTypes);
     }
  )
}

AST.TypeNode basic_type() : {
  Token t = null; AST.PrimitiveTypeKind kind = null;
}{
( t=<K_BYTE>     {kind = AST.K_BYTE();}
| t=<K_SHORT>    {kind = AST.K_SHORT();}
| t=<K_CHAR>     {kind = AST.K_CHAR();}
| t=<K_INT>      {kind = AST.K_INT();}
| t=<K_LONG>     {kind = AST.K_LONG();}
| t=<K_FLOAT>    {kind = AST.K_FLOAT();}
| t=<K_DOUBLE>   {kind = AST.K_DOUBLE();}
| t=<K_BOOLEAN>  {kind = AST.K_BOOLEAN();}
) {return new AST.TypeNode(p(t), new AST.PrimitiveType(kind), false);}
}

AST.TypeNode class_type() : {Token n;}{
  n=<FQCN> {return new AST.TypeNode(p(n), new AST.ReferenceType(n.image, true), false);}
| n=id()   {return new AST.TypeNode(p(n), new AST.ReferenceType(c(n), false), false);}
}

// A dotted qualified class name (at least one dot), e.g. java.lang.Math. Used as
// the receiver of a static call so `java.lang.Math::max(...)` works without an
// import. (Segments must be identifiers; a basic-type keyword like Long is not.)
AST.TypeNode dotted_class_type() : {Token n; StringBuilder sb = new StringBuilder();}{
  n=id() {sb.append(c(n));} ("." n=id() {sb.append('.').append(c(n));})+ {
    return new AST.TypeNode(p(n), new AST.ReferenceType(sb.toString(), true), false);
  }
}

// A basic-type keyword (Long, Int, ...) as the receiver of a static call maps to
// its boxed class, so `Long::toString(42L)` calls java.lang.Long.toString.
AST.TypeNode boxed_class_type() : {Token t;}{
  ( t=<K_BYTE> | t=<K_SHORT> | t=<K_CHAR> | t=<K_INT> | t=<K_LONG> | t=<K_FLOAT> | t=<K_DOUBLE> | t=<K_BOOLEAN> ) {
    return new AST.TypeNode(p(t), new AST.ReferenceType(boxedName(t.image), true), false);
  }
}

AST.TypeNode raw_type() :{AST.TypeNode ty; Token n; StringBuilder sb = new StringBuilder();}{
  ty = basic_type() {return ty;}
| n=<FQCN> {return new AST.TypeNode(p(n), new AST.ReferenceType(n.image, true), false);}
| n=id() {sb.append(c(n));} (LOOKAHEAD("." <ID> ("." | "[" | "]" | "=" | ")" | "(" | "," | ";" | ">" | "{" | "?" | <ID> | <EOL> | <EOF>)) "." n=id() {sb.append(".").append(c(n));})* {
    String name = sb.toString();
    boolean isFqcn = name.contains(".");
    return new AST.TypeNode(p(n), new AST.ReferenceType(name, isFqcn), false);
  }
}

// Parses a type parameter list: [T], [T extends Bound]
List<AST.TypeParameter> type_params() : {
  ArrayBuffer<AST.TypeParameter> params = new ArrayBuffer<AST.TypeParameter>();
  Token name; AST.TypeNode bound = null; AST.TypeNode con = null;
  ArrayBuffer<AST.TypeNode> cons = null;
}{
  "[" name=id() [<K_EXTENDS> bound=type()] {cons = new ArrayBuffer<AST.TypeNode>();}
      [":" con=constraint_ref() {append(cons, con);} ("+" con=constraint_ref() {append(cons, con);})*]
      { params.append(new AST.TypeParameter(p(name), c(name), option(bound), toList(cons))); bound = null; }
  ("," name=id() [<K_EXTENDS> bound=type()] {cons = new ArrayBuffer<AST.TypeNode>();}
      [":" con=constraint_ref() {append(cons, con);} ("+" con=constraint_ref() {append(cons, con);})*]
      { params.append(new AST.TypeParameter(p(name), c(name), option(bound), toList(cons))); bound = null; })*
  "]" { return toList(params); }
}

// A type-class constraint in a bound, e.g. the `Numeric` in `[T: Numeric]`. For
// now a bare trait name (single-parameter traits, the param is implied);
// multi-parameter constraints are a later stage.
AST.TypeNode constraint_ref() : { AST.TypeNode ty; }{
  ty=class_type() { return ty; }
}

// Parses a type argument list: [String], [Foo[Bar]], etc.
List<AST.TypeNode> type_arguments() : {
  AST.TypeNode ty;
  ArrayBuffer<AST.TypeNode> args = new ArrayBuffer<AST.TypeNode>();
}{
  "[" eols()
    ty=type() { append(args, ty); }
    ("," eols() ty=type() { append(args, ty); })*
  eols() "]" { return toList(args); }
}

AST.TypeNode void_type() :{Token t;}{
  t=<K_VOID> {return new AST.TypeNode(p(t), new AST.PrimitiveType(AST.K_VOID()), false);}
}

AST.TypeNode type() : {
  int d = 0; ArrayBuffer<AST.TypeDescriptor> args = new ArrayBuffer<AST.TypeDescriptor>();
  ArrayBuffer<AST.TypeDescriptor> fargs = new ArrayBuffer<AST.TypeDescriptor>();
  AST.TypeNode arg, c, r;
  boolean isRelaxed = false;
  AST.TypeDescriptor core = null;
  AST.TypeDescriptor left = null;
  Location loc = null;
  Token start = null;
  AST.TypeDescriptor wcBound = null;
}{
  ("+" {isRelaxed = true;})?
  (
    // Wildcard type: ?, ? extends T, ? super T
    LOOKAHEAD( "?" )
      start="?" {
        loc = p(start);
        scala.Option<AST.TypeDescriptor> upperBound = scala.Option.apply(null);
        scala.Option<AST.TypeDescriptor> lowerBound = scala.Option.apply(null);
      }
      [ LOOKAHEAD(<K_EXTENDS> | <K_SUPER>)
        ( <K_EXTENDS> arg=type() { upperBound = scala.Option.apply(arg.desc()); }
        | <K_SUPER> arg=type() { lowerBound = scala.Option.apply(arg.desc()); }
        )
      ] {
        core = new AST.WildcardType(upperBound, lowerBound);
      }
  | LOOKAHEAD( "(" )
      start="(" eols()
        [ arg=type() { append(fargs, arg.desc()); } ("," eols() arg=type() { append(fargs, arg.desc()); })* ]
      eols() ")" eols() <ARROW> eols() r=return_type() {
        core = new AST.FunctionType(toList(fargs), r.desc());
        loc = p(start);
      }
  | c=raw_type()
    [LOOKAHEAD(2) "[" arg=type() {append(args, arg.desc());} ("," arg=type() {append(args, arg.desc());})* "]" ] {
      core = args.size() > 0 ? new AST.ParameterizedType(c.desc(), toList(args)) : c.desc();
      loc = c.location();
    }
  )
  {left = core;}
  // Array dims: T[] or T?[] (nullable elements; the lexer sees "?[" as one
  // token). The whole choice is lookahead-guarded so the loop only enters
  // on an actual empty bracket pair.
  ( LOOKAHEAD(2)
    ( "[" "]" {left = new AST.ArrayType(left);}
    | <SAFE_INDEX> "]" {left = new AST.ArrayType(new AST.NullableType(left));}
    )
  )*
  // Lookahead avoids conflicts with nested expansions that also start with "->".
  [ LOOKAHEAD(2) <ARROW> eols() r=type() {
      ArrayBuffer<AST.TypeDescriptor> p = new ArrayBuffer<AST.TypeDescriptor>();
      append(p, left);
      left = new AST.FunctionType(toList(p), r.desc());
    }
  ]
  // Nullable type marker: T?
  [ LOOKAHEAD(1) <QUESTION> { left = new AST.NullableType(left); } ]
  {
    return new AST.TypeNode(loc, left, isRelaxed);
  }
}

AST.TypeNode return_type() :{AST.TypeNode type;}{
  (type = void_type() | type = type()) {return type;}
}

AST.Argument argument() :{Token t; AST.TypeNode type; AST.Expression defaultValue = null; boolean isVararg = false;}{
  t=id() ":" type = type() ["..." {isVararg = true;}] ["=" eols() defaultValue = term()]
  {return new AST.Argument(p(t), c(t), type, defaultValue, isVararg);}
}

List<AST.Argument> args() :{ArrayBuffer<AST.Argument> as = new ArrayBuffer<AST.Argument>(); AST.Argument a;}{
  [a = argument() {append(as, a);} ("," a = argument() {append(as, a);})*] {return toList(as);}
}

AST.Argument lambda_argument() :{Token t; AST.TypeNode type = null;}{
  t=id() [":" type = type()] {return new AST.Argument(p(t), c(t), type, null, false);}
}

List<AST.Argument> lambda_args() :{ArrayBuffer<AST.Argument> as = new ArrayBuffer<AST.Argument>(); AST.Argument a;}{
  [a = lambda_argument() {append(as, a);} ("," a = lambda_argument() {append(as, a);})*] {return toList(as);}
}

void lambda_arg_head() :{}{
  id() [":" type()]
}

void lambda_head() :{}{
  "(" eols() [lambda_arg_head() ("," eols() lambda_arg_head())*] eols() ")" eols() <ARROW>
}

AST.DelegatedFieldDeclaration delegate_decl(int modifiers) : {
  Token start, keyword, name;
  AST.TypeNode type = null;
  AST.Expression init = null;
}{
  {enterSection();}
  start="forward" (keyword="val" | keyword="var") name=id() ":" type = type()
  ["=" eols() init=term()] eos() {
    int declMods = modifiers;
    if (keyword.image.equals("val")) declMods |= AST.M_FINAL();
    return new AST.DelegatedFieldDeclaration(p(start), declMods, c(name), type, init);
  }
}

AST.FieldDeclaration field_decl(int modifiers):{
  Token keyword, name;
  AST.TypeNode type = null;
  AST.Expression init = null;
}{
  {enterSection();}
  (keyword="val" | keyword="var") name=id() ":" type=type()
  ["=" eols() init=term()] eos() {
    int declMods = modifiers;
    if (keyword.image.equals("val")) declMods |= AST.M_FINAL();
    return new AST.FieldDeclaration(p(keyword), declMods, c(name), type, init);
  }
}

AST.BlockElement block_element():{AST.BlockElement s; Token lbl; AST.Expression lp;}{
  LOOKAHEAD({getToken(1).kind == ID && getToken(2).image.equals(":") &&
             (getToken(3).image.equals("while") || getToken(3).image.equals("for")
              || getToken(3).image.equals("foreach") || getToken(3).image.equals("do"))})
  lbl=id() ":" ( lp=while_expression() | lp=for_expression() | lp=foreach_expression()
               | LOOKAHEAD("do" "{") lp=do_while_expression() ) {
    return new AST.LabeledLoop(p(lbl), c(lbl), lp);
  }
| s=local_var_declaration()  {return s;}
| s=if_expression()          {return s;}
| s=while_expression()       {return s;}
| s=for_expression()         {return s;}
| s=select_expression()      {return s;}
| s=block()                  {return s;}
| s=try_expression()         {return s;}
| s=terminated_throw_expression()    {return s;}
| s=terminated_break_expression()    {return s;}
| s=terminated_continue_expression() {return s;}
| s=terminated_return_expression()   {return s;}
| s=synchronized_expression()        {return s;}
| s=foreach_expression()             {return s;}
| LOOKAHEAD("do" "{") s=do_while_expression() {return s;}
| s=expression_element()     {return s;}
}

// End of section
void eos() :{} {
  // After the terminator, absorb any further EOL tokens. Leading-dot
  // continuation peeks past newlines (see suffixContinues), which can
  // tokenize a blank line's EOL while still IN_STATEMENT; that buffered
  // token would otherwise leak past leaveSection() and trip the next
  // member/statement. Trailing blank lines are insignificant anyway.
  (";" | <EOL> | <EOF>) { leaveSection(); } eols()
}

void eols() :{} {
  // Lookahead reduces choice conflicts with EOL-consuming constructs.
  ( LOOKAHEAD(2) <EOL> )*
}

void eos_or_block_end() :{} {
  (";" | <EOL> | <EOF>) { leaveSection(); } eols()
| LOOKAHEAD("}") { leaveSection(); }
}

AST.BlockElement local_var_declaration() :{
  Token keyword, t; int declMods = 0; AST.TypeNode ty = null; AST.Expression e = null;
  ArrayBuffer<String> names = new ArrayBuffer<String>();
}{
  {enterSection();}
  (keyword="val" {declMods = AST.M_FINAL();} | keyword="var" {declMods = 0;})
  ( LOOKAHEAD("(")
    "(" t=id() {append(names, c(t));} ("," t=id() {append(names, c(t));})+ ")" "=" eols() e=term()
    eos_or_block_end() {return new AST.DestructuringDeclaration(p(keyword), declMods, toList(names), e);}
  | t=id()
    (
      ":" ty=type() ["=" eols() e=term()]
    | "=" eols() e=term()
    )
    eos_or_block_end() {return new AST.LocalVariableDeclaration(p(keyword), declMods, c(t), ty, e);}
  )
}

AST.BreakExpression terminated_break_expression() :{Token t, l = null;}{
  {enterSection();}
  t="break" [LOOKAHEAD({getToken(1).kind == ID && getToken(1).beginLine == t.endLine}) l=id()] eos_or_block_end() {
    return new AST.BreakExpression(p(t), l == null ? null : c(l));
  }
}

AST.BreakExpression break_expression() :{Token t, l = null;}{
  t="break" [LOOKAHEAD({getToken(1).kind == ID && getToken(1).beginLine == t.endLine}) l=id()] {
    return new AST.BreakExpression(p(t), l == null ? null : c(l));
  }
}

AST.ContinueExpression terminated_continue_expression() :{Token t, l = null; AST.ContinueExpression st;}{
  {enterSection();}
  t="continue" [LOOKAHEAD({getToken(1).kind == ID && getToken(1).beginLine == t.endLine}) l=id()] eos_or_block_end() {
    return new AST.ContinueExpression(p(t), l == null ? null : c(l));
  }
}

AST.ContinueExpression continue_expression() :{Token t, l = null; AST.ContinueExpression st;}{
  t="continue" [LOOKAHEAD({getToken(1).kind == ID && getToken(1).beginLine == t.endLine}) l=id()] {
    return new AST.ContinueExpression(p(t), l == null ? null : c(l));
  }
}

AST.ThrowExpression terminated_throw_expression() :{Token t; AST.Expression e;}{
  {enterSection();}
  t="throw" e=term() eos_or_block_end() {return new AST.ThrowExpression(p(t), e);}
}

AST.ThrowExpression throw_expression() :{Token t; AST.Expression e;}{
  t="throw" e=term() {return new AST.ThrowExpression(p(t), e);}
}

AST.LocalVariableDeclaration resource_decl() :{
  Token t; Token name; AST.TypeNode type = null; AST.Expression init;
}{
  t="val" eols() name=<ID> [":" type=type()] "=" eols() init=term()
  {return new AST.LocalVariableDeclaration(p(t), 0, c(name), type, init);}
}

List<AST.LocalVariableDeclaration> resource_list() :{
  AST.LocalVariableDeclaration r;
  ArrayBuffer<AST.LocalVariableDeclaration> rs = new ArrayBuffer<AST.LocalVariableDeclaration>();
}{
  r=resource_decl() {append(rs, r);} (";" eols() r=resource_decl() {append(rs, r);})*
  {return toList(rs);}
}

AST.TryExpression try_expression() :{
  Token t; AST.Argument a; AST.BlockExpression b1, b2, b3 = null; AST.TypeNode ety;
  List<AST.LocalVariableDeclaration> resources = (List<AST.LocalVariableDeclaration>)AST.NIL();
  ArrayBuffer<Tuple2<AST.Argument,AST.BlockExpression>> as = new ArrayBuffer<Tuple2<AST.Argument, AST.BlockExpression>>();
  java.util.ArrayList<AST.TypeNode> extraTypes;
}{
  t="try" [LOOKAHEAD(2) "(" resources=resource_list() ")"]
  b1=block() (
    "catch" a=argument() {extraTypes = new java.util.ArrayList<AST.TypeNode>();}
    // Multi-catch: catch e: A | B desugars to one clause per type sharing the body
    ("|" ety=type() {extraTypes.add(ety);})*
    b2=block() {
      append(as, new Tuple2<AST.Argument, AST.BlockExpression>(a, b2));
      for (AST.TypeNode ty2 : extraTypes) {
        append(as, new Tuple2<AST.Argument, AST.BlockExpression>(new AST.Argument(a.location(), a.name(), ty2, null, false), b2));
      }
    }
  )*
  ["finally" b3=block()] {return new AST.TryExpression(p(t), resources, b1, toList(as), b3);}
}

AST.Expression expression_element() :{AST.Expression e;}{
  {enterSection();}
  e=assignable() eos_or_block_end() {return e;}
}

AST.IfExpression if_expression() :{Token t; AST.Expression e; AST.BlockExpression b1, b2 = null; AST.IfExpression elif = null; ArrayBuffer<AST.BlockElement> elifElems = new ArrayBuffer<AST.BlockElement>();}{
  t="if" e=term() b1=block()
  [ LOOKAHEAD(2) "else"
    ( b2=block()
    | elif=if_expression() {
        // else-if chain: wrap the nested if in a synthetic block
        append(elifElems, elif);
        b2 = new AST.BlockExpression(elif.location(), toList(elifElems));
      }
    )
  ]
  {return new AST.IfExpression(p(t), e, b1, b2);}
}

AST.Pattern case_pattern() :{
  AST.Pattern p; AST.Expression guard = null;
}{
  p=simple_pattern() ["when" guard=logical_or() { p = new AST.GuardedPattern(p.location(), p, guard); }]
  { return p; }
}

AST.Pattern simple_pattern() :{
  Token t, n; AST.Expression e; AST.TypeNode ty;
  List<AST.Pattern> bindings;
  ArrayBuffer<String> names = new ArrayBuffer<String>();
}{
  LOOKAHEAD({getToken(1).kind == ID && getToken(1).image.equals("_")})
  t=<ID> { return new AST.WildcardPattern(p(t)); }
| LOOKAHEAD(2, id() "(")
  t=id() "(" bindings=destructuring_bindings() ")" { return new AST.DestructuringPattern(p(t), c(t), bindings); }
| LOOKAHEAD(2, id() "is")
  t=id() "is" ty=type() { return new AST.TypePattern(p(t), c(t), ty); }
| LOOKAHEAD(2, id() "when")
  t=id() { return new AST.BindingPattern(p(t), c(t)); }
  // Regex pattern: case re"..." (g1, g2): matches a String subject and binds
  // its capture groups. The literal is validated at compile time (syntax and
  // group count vs binding count).
| t=<RE_STRING> [ "(" n=id() {append(names, c(n));} ("," n=id() {append(names, c(n));})* ")" ]
  { return new AST.RegexPattern(p(t), t.image.substring(3, t.image.length() - 1), toList(names)); }
| e=term() { return new AST.ExpressionPattern(e); }
}

// Patterns allowed inside destructuring: binding name, wildcard, or nested destructuring
AST.Pattern destructuring_field_pattern() :{
  Token t; List<AST.Pattern> bindings;
}{
  LOOKAHEAD({getToken(1).kind == ID && getToken(1).image.equals("_")})
  t=<ID> { return new AST.WildcardPattern(p(t)); }
| LOOKAHEAD(2, id() "(")
  t=id() "(" bindings=destructuring_bindings() ")" { return new AST.DestructuringPattern(p(t), c(t), bindings); }
| t=<ID> { return new AST.BindingPattern(p(t), c(t)); }
}

List<AST.Pattern> destructuring_bindings() :{
  AST.Pattern pat; ArrayBuffer<AST.Pattern> bindings = new ArrayBuffer<AST.Pattern>();
}{
  [pat=destructuring_field_pattern() { append(bindings, pat); } ("," pat=destructuring_field_pattern() { append(bindings, pat); })*]
  { return toList(bindings); }
}

AST.SelectExpression select_expression() :{
  Token t1, t2; AST.Expression e1; AST.Pattern p;
  ArrayBuffer<AST.Pattern> patterns = new ArrayBuffer<AST.Pattern>();
  List<AST.BlockElement> ss = null;
  ArrayBuffer<Tuple2<List<AST.Pattern>, AST.BlockExpression>> branches = new ArrayBuffer<Tuple2<List<AST.Pattern>, AST.BlockExpression>>();
  AST.BlockExpression elseBlock = null ;
}{
  t1="select" e1=term() eols() "{" eols()
    (
      LOOKAHEAD({la("case")})
      t2="case" p=case_pattern() {append(patterns, p);} ("," p=case_pattern() {append(patterns, p);})* ":" eols() ss=block_elements() {
        append(branches, new Tuple2<List<AST.Pattern>, AST.BlockExpression>(toList(patterns), new AST.BlockExpression(p(t2), ss)));
        patterns = new ArrayBuffer<AST.Pattern>();
      }
      eols()
    )*
    eols()
    [LOOKAHEAD({la("else")})
      t2="else" ":" eols() [ss=block_elements()] { elseBlock = new AST.BlockExpression(p(t2), ss); }
    ]
  eols() "}" {
    return new AST.SelectExpression(p(t1), e1, toList(branches), elseBlock);
  }
}

AST.ReturnExpression terminated_return_expression() :{Token t; AST.Expression e = null;}{
  {enterSection();}
  t="return"
  // Take a return value unless the next token already terminates the statement
  [ LOOKAHEAD({ getToken(1).kind != EOL && getToken(1).kind != EOF && !la(";") && !la("}") }) e=term() ]
  eos_or_block_end() {return new AST.ReturnExpression(p(t), e);}
}

AST.ReturnExpression return_expression() :{Token t; AST.Expression e = null;}{
  t="return" [LOOKAHEAD(2) e=term()] {return new AST.ReturnExpression(p(t), e);}
}

AST.SynchronizedExpression synchronized_expression() :{Token t; AST.Expression e = null; AST.BlockExpression b;}{
  t="synchronized" [LOOKAHEAD({!la("{")}) e=term()] b=block() {return new AST.SynchronizedExpression(p(t), e, b);}
}

AST.WhileExpression while_expression() :{Token t; AST.Expression e; AST.BlockExpression b;}{
  t="while" e=term() b=block() {return new AST.WhileExpression(p(t), e, b);}
}

AST.DoWhileExpression do_while_expression() :{Token t; AST.Expression e; AST.BlockExpression b;}{
  t="do" b=block() "while" {enterSection();} e=term() eos_or_block_end() {
    return new AST.DoWhileExpression(p(t), b, e);
  }
}

AST.ForeachExpression foreach_expression() :{Token t, k = null, v = null; AST.Argument a; AST.Expression e; AST.BlockExpression b;}{
  t="foreach"
  ( LOOKAHEAD("(")
    "(" k=id() "," v=id() ")" (LOOKAHEAD({la("in")}) id()) e=term() b=block() {
      return desugarMapForeach(p(t), c(k), c(v), e, b);
    }
  | a=argument() (LOOKAHEAD({la("in")}) id()) e=term() b=block() {
      return new AST.ForeachExpression(p(t), a, e, b);
    }
  )
}

AST.ForInitializer for_initializer() :{AST.BlockElement d; AST.Expression e; Token t;}{
  d=local_var_declaration() {
    if (d instanceof AST.DestructuringDeclaration) {
      throw new ParseException("destructuring declarations are not allowed in for initializers");
    }
    return new AST.ForInitDeclaration((AST.LocalVariableDeclaration)d);
  }
| e=expression_element() { return new AST.ForInitExpression(e); }
| t=";" { return new AST.ForInitEmpty(p(t)); }
}

AST.ForExpression for_expression() :{Token t; AST.ForInitializer init; AST.Expression e1 = null, e2 = null; AST.BlockExpression b;}{
  t="for" init=for_initializer()
  [e1=term()] ";" [LOOKAHEAD({!la("{")}) e2=term()] b=block() {
  	return new AST.ForExpression(p(t), init, e1, e2, b);
  }
}

AST.Expression expression() :{AST.Expression e;}{
  e=if_expression()          {return e;}
| e=while_expression()       {return e;}
| e=for_expression()         {return e;}
| e=select_expression()      {return e;}
| e=block()                  {return e;}
| e=try_expression()         {return e;}
| e=throw_expression()       {return e;}
| e=break_expression()       {return e;}
| e=continue_expression()    {return e;}
| e=return_expression()      {return e;}
| e=synchronized_expression() {return e;}
| e=foreach_expression()      {return e;}
| e=assignable()             {return e;}
}

AST.Expression term() :{AST.Expression e;}{
  e = expression() { return e; }
}

AST.Expression assignable() :{Token t; AST.Expression a, b; }{
  a=pipeline()
  [ LOOKAHEAD(2)
    ( t="="  eols() b=expression() {a = new AST.Assignment(p(t), a, b);}
    | t="+=" eols() b=expression() {a = new AST.AdditionAssignment(p(t), a, b);}
    | t="-=" eols() b=expression() {a = new AST.SubtractionAssignment(p(t), a, b);}
    | t="*=" eols() b=expression() {a = new AST.MultiplicationAssignment(p(t), a, b);}
    | t="/=" eols() b=expression() {a = new AST.DivisionAssignment(p(t), a, b);}
    | t="%=" eols() b=expression() {a = new AST.ModuloAssignment(p(t), a, b);}
    | t="&=" eols() b=expression() {a = new AST.BitAndAssignment(p(t), a, b);}
    | t="|=" eols() b=expression() {a = new AST.BitOrAssignment(p(t), a, b);}
    | t="^=" eols() b=expression() {a = new AST.XorAssignment(p(t), a, b);}
    | t="<<=" eols() b=expression() {a = new AST.LeftShiftAssignment(p(t), a, b);}
    | t=">>=" eols() b=expression() {a = new AST.MathRightShiftAssignment(p(t), a, b);}
    | t=">>>=" eols() b=expression() {a = new AST.LogicalRightShiftAssignment(p(t), a, b);}
    )
  ]{return a;}
}

// Pipeline: e |> f desugars to f(e); e |> f(a) to f(e, a); e |> obj.m(a) to
// obj.m(e, a) — the left value is injected as the first argument (Elixir
// style). Sits between the assignment level and logical-or so a whole
// pipeline can be assigned: val r = xs |> filter { ... } |> println
AST.Expression pipeline() :{Token t; AST.Expression a, b; }{
  a=logical_or()
  // A newline before |> keeps the pipeline going (same semantic-predicate
  // technique as the leading-dot method-chain continuation), so stages can
  // be stacked one per line.
  ( LOOKAHEAD({ pipeContinuationFollows() })
    eols() t="|>" eols() b=logical_or() {a = pipeInto(p(t), a, b);}
  )*
  { return a; }
}

AST.Expression logical_or() :{Token t; AST.Expression a, b; }{
  a=logical_and()
  ( LOOKAHEAD(2)
    ( t="||" eols() b=logical_and() {a = new AST.LogicalOr(p(t), a, b);}
    | t="?:" eols() ( b=throw_expression() | b=return_expression() | b=logical_and() ) {a = new AST.Elvis(p(t), a, b);}
    )
  )*
  { return a; }
}

AST.Expression logical_and() :{Token t; AST.Expression a, b; }{
  a=bit_or() (LOOKAHEAD(2) t="&&" eols() b=bit_or() {a = new AST.LogicalAnd(p(t), a, b);})* {return a;}
}

AST.Expression bit_or() :{Token t; AST.Expression a, b; }{
  a=xor() (LOOKAHEAD(2) t="|" eols() b=xor() {a = new AST.BitOr(p(t), a, b);})* {return a;}
}

AST.Expression xor() :{Token t; AST.Expression a, b;}{
  a = bit_and() (LOOKAHEAD(2) t="^" eols() b=bit_and() {a = new AST.XOR(p(t), a, b);})* {return a;}
}

AST.Expression bit_and() :{Token t; AST.Expression a, b; }{
  a=equal() (LOOKAHEAD(2) t = "&" eols() b=equal() {a = new AST.BitAnd(p(t), a, b);})* {return a;}
}

AST.Expression equal() :{ Token t; AST.Expression a, b; }{
  a=comparative()
  ( LOOKAHEAD(2)
    ( t="===" eols() b=comparative() {a= new AST.ReferenceEqual(p(t), a, b);}
    | t="!==" eols() b=comparative() {a= new AST.ReferenceNotEqual(p(t), a, b);}
    | t="=="  eols() b=comparative() {a= new AST.Equal(p(t), a, b);}
    | t="!="  eols() b=comparative() {a= new AST.NotEqual(p(t), a, b);}
    )
  )* {return a;}
}

AST.Expression comparative() : { Token t; AST.Expression a, b; AST.TypeNode type; }{
  a=range_expr()
  ( LOOKAHEAD(2)
    ( t=<LTEQ> eols() b=range_expr() {a = new AST.LessOrEqual(p(t), a, b);}
    | t=<GTEQ> eols() b=range_expr() {a = new AST.GreaterOrEqual(p(t), a, b);}
    | t="<"  eols() b=range_expr() {a = new AST.LessThan(p(t), a, b);}
    | t=">"  eols() b=range_expr() {a = new AST.GreaterThan(p(t), a, b);}
    | t="is" eols() type = type() {a = new AST.IsInstance(p(t), a, type);}
    )
  )* {return a;}
}

// Range literals a..b (inclusive) and a..<b (exclusive), desugared to
// new onion.Range(a, b, inclusive). The runtime Range is Iterable, so
// foreach works without further compiler support.
AST.Expression range_expr() :{Token t; AST.Expression a, b;}{
  a=bit_shift()
  [ LOOKAHEAD(2)
    ( t="..<" eols() b=bit_shift() { a = rangeNew(p(t), a, b, false); }
    | t=".." eols() b=bit_shift() { a = rangeNew(p(t), a, b, true); }
    )
  ]
  {return a;}
}

AST.Expression bit_shift() :{Token t; AST.Expression e1, e2;}{
  e1=additive()
( LOOKAHEAD(2)
  ( t="<<" eols() e2=additive()    {e1 = new AST.MathLeftShift(p(t), e1, e2);}
  | t=">>" eols() e2=additive()    {e1 = new AST.MathRightShift(p(t), e1, e2);}
  | t=">>>"eols() e2=additive()    {e1 = new AST.LogicalRightShift(p(t), e1, e2);}
  )
)* { return e1; }
}

AST.Expression additive() :{Token t; AST.Expression e1, e2;}{
  e1=unary_prefix()
( LOOKAHEAD(2)
  ( t="+" eols() e2=unary_prefix() {e1 = new AST.Addition(p(t), e1, e2);}
  | t="-" eols() e2=unary_prefix() {e1 = new AST.Subtraction(p(t), e1, e2);}
  )
)* {return e1;}
}

AST.Expression unary_prefix() :{Token t; AST.Expression e;}{
( t="+" e=unary_prefix() {e = new AST.Posit(p(t), e);}
| t="-" e=unary_prefix() {e = new AST.Negate(p(t), e);}
| t="!" e=unary_prefix() {e = new AST.Not(p(t), e);}
| t=<BN> e=unary_prefix() {e = new AST.BitNot(p(t), e);}
| e=multitive()
) {return e;}
}

AST.Expression multitive() :{Token t; AST.Expression e1, e2;}{
  e1=primary_suffix()
( LOOKAHEAD(2)
  ( t="*" eols() e2=primary_suffix()  {e1 = new AST.Multiplication(p(t), e1, e2);}
  | t="/" eols() e2=primary_suffix()  {e1 = new AST.Division(p(t), e1, e2);}
  | t="%" eols() e2=primary_suffix()  {e1 = new AST.Modulo(p(t), e1, e2);}
  )
)* {return e1;}
}

AST.Expression primary_suffix() : {
  Token t, n; AST.Expression e, a = null; List<AST.Expression> args = (List<AST.Expression>)AST.NIL();
  List<AST.TypeNode> tas = (List<AST.TypeNode>)AST.NIL();
  AST.TypeNode type;
  AST.ClosureExpression tl = null;
}{
  e=primary()
  // The loop continues only when suffixContinues() says so (a same-line
  // suffix here, or a leading-dot chain continuing across newlines). A
  // semantic guard keeps <EOL> out of the continuation first-set. When a
  // dot continuation follows, eat the intervening newlines first; same-line
  // suffixes leave the optional eols() unmatched.
( LOOKAHEAD({ suffixContinues() })
  eols()
  ( t="[" eols() a=term() eols() "]"                                                              {e = new AST.Indexing(p(t), e, a);}
  | t=<SAFE_INDEX> eols() a=term() eols() "]"                                                     {e = new AST.SafeIndexing(p(t), e, a);}
  | e=dot_suffix(e)
  | e=safe_access_suffix(e)
  | t=<K_AS> eols() type=type()                                                                    {e = new AST.Cast(p(t), e, type);}
  | t="++"                                                                                        {e = new AST.PostIncrement(p(t), e);}
  | t=<NOT_NULL>                                                                                  {e = new AST.NotNullAssertion(p(t), e);}
  | t="--"                                                                                        {e = new AST.PostDecrement(p(t), e);}
  )
)* {return e;}
}

AST.Expression dot_suffix(AST.Expression e) : {
  Token t, n; List<AST.Expression> args = (List<AST.Expression>)AST.NIL();
  List<AST.TypeNode> tas = (List<AST.TypeNode>)AST.NIL(); AST.ClosureExpression tl = null;
}{
  t="." eols() n=id() (
      LOOKAHEAD( type_arguments() eols() "(" )
        tas=type_arguments() eols() "(" eols() args=terms() ")"
        [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
          { args = AST.appendToList(args, tl); tl = null; e = new AST.MethodCall(p(t), e, c(n), args, tas); }
    | LOOKAHEAD(1) "(" eols() args=terms() ")"
        [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
          { args = AST.appendToList(args, tl); tl = null; e = new AST.MethodCall(p(t), e, c(n), args); }
    | [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()] {
        if (tl != null) {
          args = (List<AST.Expression>)AST.NIL();
          args = AST.appendToList(args, tl);
          tl = null;
          e = new AST.MethodCall(p(t), e, c(n), args);
        } else {
          e = new AST.MemberSelection(p(t), e, c(n));
        }
      }
    ) { return e; }
}

AST.Expression safe_access_suffix(AST.Expression e) : {
  Token t, n; List<AST.Expression> args = (List<AST.Expression>)AST.NIL();
  List<AST.TypeNode> tas = (List<AST.TypeNode>)AST.NIL(); AST.ClosureExpression tl = null;
}{
  t=<SAFE_ACCESS> eols() n=id() (
      LOOKAHEAD( type_arguments() eols() "(" )
        tas=type_arguments() eols() "(" eols() args=terms() ")"
        [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
          { args = AST.appendToList(args, tl); tl = null; e = new AST.SafeMethodCall(p(t), e, c(n), args, tas); }
    | LOOKAHEAD(1) "(" eols() args=terms() ")"
        [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
          { args = AST.appendToList(args, tl); tl = null; e = new AST.SafeMethodCall(p(t), e, c(n), args); }
    | [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()] {
        if (tl != null) {
          args = (List<AST.Expression>)AST.NIL();
          args = AST.appendToList(args, tl);
          tl = null;
          e = new AST.SafeMethodCall(p(t), e, c(n), args);
        } else {
          e = new AST.SafeMemberSelection(p(t), e, c(n));
        }
      }
    ) { return e; }
}

AST.Expression primary() : {
  Token n = null, t; AST.TypeNode ty = null; AST.Expression e;
  List<AST.Expression> es = (List<AST.Expression>)AST.NIL();
  List<AST.Argument> args = (List<AST.Argument>)AST.NIL();
  List<AST.TypeNode> tas = (List<AST.TypeNode>)AST.NIL();
  AST.BlockExpression body;
  AST.ClosureExpression tl = null;
}{
  LOOKAHEAD( "super" eols() "." eols() id() type_arguments() "(" )
    t="super" eols() "." eols() n=id() tas=type_arguments() "(" es=terms() ")"
    [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
    { es = AST.appendToList(es, tl); return new AST.SuperMethodCall(p(t), c(n), es, tas); }
| t="super" eols() "." eols() n=id() [LOOKAHEAD(2) "(" es=terms() ")"]
    [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
    { es = AST.appendToList(es, tl); return new AST.SuperMethodCall(p(t), c(n), es); }
| LOOKAHEAD( boxed_class_type() "::" id() type_arguments() "(" ) ty=boxed_class_type() t="::" n=id() tas=type_arguments() "(" es=terms() ")"
    [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
    { es = AST.appendToList(es, tl); return new AST.StaticMethodCall(p(t), ty, c(n), es, tas); }
| LOOKAHEAD( boxed_class_type() "::" id() "(" ) ty=boxed_class_type() t="::" n=id() "(" es=terms() ")"
    [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
    { es = AST.appendToList(es, tl); return new AST.StaticMethodCall(p(t), ty, c(n), es); }
| LOOKAHEAD( boxed_class_type() "::" ) ty=boxed_class_type() t="::" n=id()
    { return new AST.StaticMemberSelection(p(t), ty, c(n)); }
| LOOKAHEAD( dotted_class_type() "::" id() type_arguments() "(" ) ty=dotted_class_type() t="::" n=id() tas=type_arguments() "(" es=terms() ")"
    [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
    { es = AST.appendToList(es, tl); return new AST.StaticMethodCall(p(t), ty, c(n), es, tas); }
| LOOKAHEAD( dotted_class_type() "::" id() "(" ) ty=dotted_class_type() t="::" n=id() "(" es=terms() ")"
    [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
    { es = AST.appendToList(es, tl); return new AST.StaticMethodCall(p(t), ty, c(n), es); }
| LOOKAHEAD( dotted_class_type() "::" ) ty=dotted_class_type() t="::" n=id()
    { return new AST.StaticMemberSelection(p(t), ty, c(n)); }
| LOOKAHEAD( class_type() "::" id() type_arguments() "(" ) ty=class_type() t="::" n=id() tas=type_arguments() "(" es=terms()  ")"
    [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
    { es = AST.appendToList(es, tl); return new AST.StaticMethodCall(p(t), ty, c(n), es, tas); }
| LOOKAHEAD(4) ty=class_type() t="::" n=id() "(" es=terms()  ")"
    [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
    { es = AST.appendToList(es, tl); return new AST.StaticMethodCall(p(t), ty, c(n), es); }
| LOOKAHEAD(2) ty=class_type() t="::" n=id()                        {return new AST.StaticMemberSelection(p(t), ty, c(n));}
| LOOKAHEAD( id() type_arguments() "(" ) t=id() tas=type_arguments() "(" es=terms() ")"
    [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
    { es = AST.appendToList(es, tl); return new AST.UnqualifiedMethodCall(p(t), c(t), es, tas); }
| LOOKAHEAD(2) t=id() "(" es=terms() ")"
    [LOOKAHEAD(trailing_lambda_head()) tl=trailing_lambda()]
    { es = AST.appendToList(es, tl); return new AST.UnqualifiedMethodCall(p(t), c(t), es); }
| LOOKAHEAD(2, id() <ARROW>) e=arrow_anonymous_function()                 {return e;}
| LOOKAHEAD(1) t=id()                                               {return new AST.Id(p(t), c(t));}
| {enterDefault();} t="[" eols() e=bracket_literal_rest(t) {leaveDefault();} {return e;}
| LOOKAHEAD( lambda_head() ) e=arrow_anonymous_function()                 {return e;}
| LOOKAHEAD("do" "[") e=do_expression()                                   {return e;}
| LOOKAHEAD("new" raw_type() "[" "]" "{") t="new" ty=raw_type() "[" "]" "{" eols() es=terms() "}"
    { return new AST.NewArrayWithValues(p(t), ty, es); }
| t="new" ty=raw_type() {
    ArrayBuffer<AST.Expression> sizes = new ArrayBuffer<AST.Expression>();
    ArrayBuffer<AST.TypeDescriptor> newTas = new ArrayBuffer<AST.TypeDescriptor>();
    AST.TypeNode taNode = null;
  }
  // Generic instantiation: new C[T, ...] or new C[T, ...](args). A bracketed
  // TYPE list ("type-shaped" content, or content followed by "(") is a
  // type-argument list; a bracketed EXPRESSION is an array dimension (see the
  // size branches below). newBracketsAreTypeArgs() makes that call by peeking.
  [ LOOKAHEAD({getToken(1).kind == LBRACKET && newBracketsAreTypeArgs()})
      "[" eols() taNode=type() { append(newTas, taNode.desc()); }
      ("," eols() taNode=type() { append(newTas, taNode.desc()); })*
      eols() "]" {
        ty = new AST.TypeNode(ty.location(), new AST.ParameterizedType(ty.desc(), toList(newTas)), ty.isRelaxed());
      }
  ]
  (
    // Handle: new Type[size] - array with size
    LOOKAHEAD(2) "[" eols() e=term() { append(sizes, e); } "]"
    ( LOOKAHEAD(2) "[" eols() e=term() { append(sizes, e); } "]" )*
    { return new AST.NewArray(p(t), ty, toList(sizes)); }
    // Handle: new Type?[size] - array of nullable elements ("?[" is one token)
  | LOOKAHEAD(2) <SAFE_INDEX> eols() e=term() { append(sizes, e); } "]"
    ( LOOKAHEAD(2) "[" eols() e=term() { append(sizes, e); } "]" )*
    {
      AST.TypeNode nty = new AST.TypeNode(ty.location(), new AST.NullableType(ty.desc()), ty.isRelaxed());
      return new AST.NewArray(p(t), nty, toList(sizes));
    }
    // Handle: new Type() or new Type - object creation
  | [LOOKAHEAD(2) "(" eols() (es=terms()) ")"]  { return new AST.NewObject(p(t), ty, es); }
  )
| t="self"                                                                {return new AST.CurrentInstance(p(t));}
| t="this"                                                                {return new AST.CurrentInstance(p(t));}
| e=integer_literal()                                                     {return e;}
| e=float_literal()                                                       {return e;}
| e=char_literal()                                                        {return e;}
| e=string_literal()                                                      {return e;}
| e=scheme_literal()                                                      {return e;}
| e=boolean_literal()                                                     {return e;}
| e=null_literal()                                                        {return e;}
| "(" eols() e=term() eols() ")"                                          {return e;}
}

AST.Expression argument_expr() :{Token n; AST.Expression e;}{
  LOOKAHEAD(2, id() "=")
    n=id() "=" eols() e=term()  {return new AST.NamedArgument(p(n), c(n), e);}
  | e=term()                    {return e;}
}

List<AST.Expression> terms() :{AST.Expression arg; ArrayBuffer<AST.Expression> args = new ArrayBuffer<AST.Expression>();}{
  // eols() before each argument and at the end lets argument lists span
  // multiple lines: f(\n a,\n b\n)
  [eols() arg=argument_expr() {append(args, arg);} ("," eols() arg=argument_expr() {append(args, arg);})* eols()] {
    return toList(args);
  }
}

// Continues a '[' that has already been consumed: either a list literal
// ([], [1, 2]) or a map literal ([:], ["a": 1, "b": 2]).
AST.Expression bracket_literal_rest(Token t) :{
  AST.Expression first, k, v;
  ArrayBuffer<AST.Expression> elems = new ArrayBuffer<AST.Expression>();
  ArrayBuffer<Tuple2<AST.Expression, AST.Expression>> entries = new ArrayBuffer<Tuple2<AST.Expression, AST.Expression>>();
}{
  ":" eols() "]" { return new AST.MapLiteral(p(t), toList(entries)); }
| "]" { return new AST.ListLiteral(p(t), toList(elems)); }
| first=argument_expr()
  ( ":" eols() v=term() { append(entries, new Tuple2<AST.Expression, AST.Expression>(first, v)); }
    ("," eols() k=term() ":" eols() v=term() { append(entries, new Tuple2<AST.Expression, AST.Expression>(k, v)); })*
    eols() "]"
    { return new AST.MapLiteral(p(t), toList(entries)); }
  | { append(elems, first); }
    ("," eols() k=argument_expr() { append(elems, k); })*
    eols() "]"
    { return new AST.ListLiteral(p(t), toList(elems)); }
  )
}

AST.ClosureExpression arrow_anonymous_function() :{
  Token t;
  List<AST.Argument> args = (List<AST.Argument>)AST.NIL();
  AST.BlockExpression body = null;
  AST.TypeNode ty = null;
  AST.Expression eb = null;
}{
  {enterDefault();}
  ( t="(" args=lambda_args() ")"
  | t=id() {
      ArrayBuffer<AST.Argument> single = new ArrayBuffer<AST.Argument>();
      append(single, new AST.Argument(p(t), c(t), null, null, false));
      args = toList(single);
    }
  )
  eols() <ARROW> eols()
  ( LOOKAHEAD("{") body=block() {
      ty = new AST.TypeNode(p(t), new AST.ReferenceType("onion.Function" + args.size(), true), true);
      leaveDefault();
      return new AST.ClosureExpression(p(t), ty, "call", args, null, body);
    }
    // Expression body: (x: Int) -> x * 2. Leave the EOL-skipping default
    // state first so the newline after the expression terminates it.
  | {leaveDefault();} eb=term() {
      ArrayBuffer<AST.BlockElement> bodyElems = new ArrayBuffer<AST.BlockElement>();
      append(bodyElems, eb);
      body = new AST.BlockExpression(eb.location(), toList(bodyElems));
      ty = new AST.TypeNode(p(t), new AST.ReferenceType("onion.Function" + args.size(), true), true);
      return new AST.ClosureExpression(p(t), ty, "call", args, null, body);
    }
  )
}

// Do notation: do[M] { x <- e1; y <- e2; ret e3 }
AST.DoExpression do_expression() :{
  Token t;
  AST.TypeNode monadType;
  List<Object> stmts;
}{
  {enterDefault();}
  t="do" "[" monadType=type() "]" "{" eols() stmts=do_clauses() eols() "}" {
    leaveDefault();
    return new AST.DoExpression(p(t), monadType, stmts);
  }
}

List<Object> do_clauses() :{
  Object stmt;
  ArrayBuffer<Object> stmts = new ArrayBuffer<Object>();
}{
  // Inside a do-block the lexer is in DEFAULT state, so newlines are skipped
  // rather than emitted as EOL tokens. Clauses are therefore separated by an
  // optional ";" or just whitespace/newlines -- keep taking clauses until "}"
  // (or EOF). Each iteration consumes either a separator ";" or another clause.
  stmt=do_clause() { append(stmts, stmt); }
  ( ";" | stmt=do_clause() { append(stmts, stmt); } )*
  { return toList(stmts); }
}

Object do_clause() :{
  Token t;
  String name;
  AST.Expression e;
}{
  // ret expr (return statement in do notation)
  LOOKAHEAD("ret")
    t="ret" eols() e=term() { return new AST.RetStatement(p(t), e); }
  // x <- expr (binding)
| LOOKAHEAD(id() eols() <LARROW>)
    t=id() eols() <LARROW> eols() e=term() { return new AST.DoBinding(p(t), c(t), e); }
  // expr (side-effect or final expression)
| e=term() { return e; }
}

// Trailing lambda: { x, y => body } or { => body } for zero args
AST.ClosureExpression trailing_lambda() :{
  Token t;
  List<AST.Argument> args = (List<AST.Argument>)AST.NIL();
  List<AST.BlockElement> stmts = (List<AST.BlockElement>)AST.NIL();
  AST.BlockExpression body;
  AST.TypeNode ty = null;
}{
  {enterDefault();}
  t="{" eols() args=lambda_args() eols() <ARROW2> eols() [stmts=block_elements()] eols() "}" {
    body = new AST.BlockExpression(p(t), stmts);
    ty = new AST.TypeNode(p(t), new AST.ReferenceType("onion.Function" + args.size(), true), true);
    leaveDefault();
    return new AST.ClosureExpression(p(t), ty, "call", args, null, body);
  }
}

// Look-ahead for trailing lambda: { [args] => ... }
void trailing_lambda_head() :{}{
  "{" eols() [lambda_arg_head() ("," eols() lambda_arg_head())*] eols() <ARROW2>
}

AST.Expression null_literal() :{Token t;}{
  t="null" {return new AST.NullLiteral(p(t));}
}

AST.Expression integer_literal() :{Token t; String s;}{
  t=<INTEGER> {
    s = t.image.replace("_", "");
    if(s.endsWith("B")){
      String content = chop(s);
      byte value;
      if(content.matches("0[xX].*")) {
        value = (byte)Integer.parseInt(content.substring(2), 16);
      } else if(content.matches("0[bB].*")) {
        value = (byte)Integer.parseInt(content.substring(2), 2);
      } else {
        value = Byte.parseByte(content);
      }
      return new AST.ByteLiteral(p(t), value);
    }else if(s.endsWith("S")){
      String content = chop(s);
      short value;
      if(content.matches("0[xX].*")) {
        value = (short)Integer.parseInt(content.substring(2), 16);
      } else if(content.matches("0[bB].*")) {
        value = (short)Integer.parseInt(content.substring(2), 2);
      } else {
        value = Short.parseShort(content);
      }
      return new AST.ShortLiteral(p(t), value);
    }else if(s.endsWith("L")){
      String content = chop(s);
      long value;
      if(content.matches("0[xX].*")) {
        value = Long.parseLong(content.substring(2), 16);
      } else if(content.matches("0[bB].*")) {
        value = Long.parseLong(content.substring(2), 2);
      } else {
        value = Long.parseLong(content);
      }
      return new AST.LongLiteral(p(t), value);
    }else{
      String content = s;
      int value;
      if(content.matches("0[xX].*")) {
        value = Integer.parseInt(content.substring(2), 16);
      } else if(content.matches("0[bB].*")) {
        value = Integer.parseInt(content.substring(2), 2);
      } else {
        value = Integer.parseInt(content);
      }
      return new AST.IntegerLiteral(p(t), value);
    }
  }
}

AST.Expression float_literal() :{Token t; String s;}{
  t=<FLOAT> {
  	s = t.image.replace("_", "");
    if(s.endsWith("F") || s.endsWith("f")){
      return new AST.FloatLiteral(p(t), Float.parseFloat(chop(s)));
    }else if(s.endsWith("D") || s.endsWith("d")){
      return new AST.DoubleLiteral(p(t), Double.parseDouble(chop(s)));
    }else{
      return new AST.DoubleLiteral(p(t), Double.parseDouble(s));
    }
  }
}

AST.Expression boolean_literal() :{Token t;}{
  t="true"  {return new AST.BooleanLiteral(p(t), true);}
| t="false" {return new AST.BooleanLiteral(p(t), false);}
}

// Scheme-prefixed raw literal: X"raw" desugars to the unqualified call
// X("raw") with the body kept verbatim (no escape processing).
AST.Expression scheme_literal() :{Token t;}{
  t=<RE_STRING>   {return schemeCall(t, 2);}
| t=<FILE_STRING> {return schemeCall(t, 4);}
| t=<HTTP_STRING> {return schemeCall(t, 4);}
}

AST.Expression string_literal() :{Token t; String str;}{
  t=<STRING> {
    str = t.image;
    if (str.contains("#{") && findInterpStart(str.substring(1, str.length()-1), 0) != -1) {
      return parseInterpolatedString(p(t), str);
    } else {
      return new AST.StringLiteral(p(t), unescape(chopEdge(str)));
    }
  }
| t=<MULTI_LINE_STRING> {
    str = t.image;
    if (str.contains("#{")) {
      return parseMultiLineInterpolatedString(p(t), str);
    } else {
      return new AST.StringLiteral(p(t), chopMultiLineEdge(str));
    }
  }
}

AST.CharacterLiteral char_literal() :{Token t;}{
  t=<CHARACTER> {return new AST.CharacterLiteral(p(t), unescape(chopEdge(t.image)).charAt(0));}
}
